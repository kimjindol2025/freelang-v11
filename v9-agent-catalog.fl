// FreeLang v9 Phase 2: 에이전트 카탈로그
//
// **목적**: 50개 에이전트 정의 (5개 카테고리 × 10개 에이전트)
// **구조체**:
//   - AgentSpec: 에이전트 명세 (ID, 이름, 카테고리, 설명, 도구, 반복 한계, 메모리)
//
// **5개 카테고리** (각 10개):
//   1. **Data (데이터)**: CSV 분석가, SQL 쿼리 작성기, JSON 파서, 데이터 검증, ...
//      - 역할: 데이터 로드, 변환, 검증, 분석
//   2. **Code (코드)**: Python 코드 작성, 버그 수정, 성능 최적화, 리팩토링, ...
//      - 역할: 코드 생성, 검증, 최적화, 디버깅
//   3. **Knowledge (지식)**: 사실 검증, 요약기, 추천 엔진, 검색기, ...
//      - 역할: 정보 검색, 요약, 검증, 추천
//   4. **Comms (통신)**: 이메일 작성, 리포트 생성, 뉴스레터, 마케팅, ...
//      - 역할: 텍스트 생성, 포매팅, 발송
//   5. **Ops (운영)**: 작업 스케줄러, 모니터링, 알림, 자동화, ...
//      - 역할: 시스템 관리, 모니터링, 자동화
//
// **핵심 함수** (11개):
//   명세: agent_spec_new, agent_spec_print
//   카탈로그: catalog_data_agents, catalog_code_agents, catalog_knowledge_agents,
//           catalog_comms_agents, catalog_ops_agents
//   조회: get_all_agents, find_agent_by_id, find_agents_by_category, main
//
// **사용 예시**:
//   var all_agents = get_all_agents()
//   var data_agents = catalog_data_agents()
//   var agent = find_agent_by_id(all_agents, "data-001")

// ==================== 에이전트 명세 ====================

struct AgentSpec {
    id: str
    name: str
    category: str          ;; data, code, knowledge, comms, ops
    description: str
    tools: [str]
    max_iterations: i32
    memory_enabled: bool
}

fn agent_spec_new(id: str, name: str, category: str, desc: str, tools: [str], max_iter: i32, use_memory: bool) -> AgentSpec {
    AgentSpec {
        id: id,
        name: name,
        category: category,
        description: desc,
        tools: tools,
        max_iterations: max_iter,
        memory_enabled: use_memory
    }
}

fn agent_spec_print(spec: AgentSpec) {
    println("[" + spec.id + "] " + spec.name)
    println("  Category: " + spec.category)
    println("  Description: " + spec.description)
    println("  Tools: " + str(length(spec.tools)))
    println("  Max iterations: " + str(spec.max_iterations))
    println("  Memory enabled: " + str(spec.memory_enabled))
    println("")
}

// ==================== 에이전트 카탈로그 (50개) ====================

;; ======== 카테고리 1: 데이터 에이전트 (10개) ========

fn catalog_data_agents() -> [AgentSpec] {
    var agents: [AgentSpec] = []

    ;; 1. CSV 분석가
    var a1_tools: [str] = ["read-csv", "validate", "filter", "analyze", "write-report"]
    agents.push(agent_spec_new("data-001", "CSV Analyst", "data", "분석: CSV 파일 로드, 검증, 필터링, 통계 분석", a1_tools, 5, true))

    ;; 2. SQL 쿼리 작성기
    var a2_tools: [str] = ["parse-query", "optimize", "execute", "fetch-results", "format-output"]
    agents.push(agent_spec_new("data-002", "SQL Query Builder", "data", "SQL 쿼리 작성 및 최적화, 실행", a2_tools, 6, false))

    ;; 3. JSON 변환기
    var a3_tools: [str] = ["parse-json", "transform", "validate", "write-json"]
    agents.push(agent_spec_new("data-003", "JSON Transformer", "data", "JSON 형식 변환 및 구조 변경", a3_tools, 4, false))

    ;; 4. 데이터 검증기
    var a4_tools: [str] = ["load-data", "check-schema", "check-nulls", "check-types", "report-errors"]
    agents.push(agent_spec_new("data-004", "Data Validator", "data", "데이터 품질 검증 및 오류 리포팅", a4_tools, 5, true))

    ;; 5. 데이터베이스 모니터
    var a5_tools: [str] = ["connect-db", "check-health", "monitor-performance", "alert-issues"]
    agents.push(agent_spec_new("data-005", "DB Monitor", "data", "데이터베이스 상태 모니터링", a5_tools, 10, true))

    ;; 6. ETL 오케스트레이터
    var a6_tools: [str] = ["extract", "transform", "load", "validate", "log"]
    agents.push(agent_spec_new("data-006", "ETL Orchestrator", "data", "데이터 추출-변환-로드 파이프라인 관리", a6_tools, 8, false))

    ;; 7. 데이터 클린징 에이전트
    var a7_tools: [str] = ["detect-anomalies", "remove-duplicates", "normalize", "impute-missing"]
    agents.push(agent_spec_new("data-007", "Data Cleaner", "data", "이상치 제거, 중복 제거, 정규화", a7_tools, 6, false))

    ;; 8. 통계 분석가
    var a8_tools: [str] = ["load-data", "calculate-stats", "test-hypothesis", "visualize", "report"]
    agents.push(agent_spec_new("data-008", "Statistician", "data", "통계적 분석 및 가설 검증", a8_tools, 7, true))

    ;; 9. 시계열 분석기
    var a9_tools: [str] = ["load-timeseries", "detect-trends", "forecast", "detect-seasonality"]
    agents.push(agent_spec_new("data-009", "TimeSeries Analyzer", "data", "시간 데이터 분석 및 예측", a9_tools, 6, true))

    ;; 10. 데이터 품질 지표 에이전트
    var a10_tools: [str] = ["measure-completeness", "measure-accuracy", "measure-consistency", "report-metrics"]
    agents.push(agent_spec_new("data-010", "Data Quality Scorer", "data", "데이터 품질 점수 계산 및 개선 제안", a10_tools, 5, false))

    agents
}

;; ======== 카테고리 2: 코드 에이전트 (10개) ========

