    agents.push(agent_spec_new("know-004", "Translator", "knowledge", "다국어 번역 및 의미 보존", c4_tools, 5, false))

    ;; 5. 질문-답변 에이전트
    var c5_tools: [str] = ["parse-question", "search-knowledge", "extract-answer", "format-response"]
    agents.push(agent_spec_new("know-005", "QA Agent", "knowledge", "자주 묻는 질문 자동 답변", c5_tools, 4, true))

    ;; 6. 지식 그래프 빌더
    var c6_tools: [str] = ["extract-entities", "identify-relations", "build-graph", "validate-connections"]
    agents.push(agent_spec_new("know-006", "Knowledge Graph Builder", "knowledge", "텍스트에서 지식 그래프 자동 구성", c6_tools, 7, false))

    ;; 7. 개념 설명 에이전트
    var c7_tools: [str] = ["identify-concept", "search-resources", "explain-simply", "provide-examples"]
    agents.push(agent_spec_new("know-007", "Concept Explainer", "knowledge", "복잡한 개념 쉽게 설명", c7_tools, 5, true))

    ;; 8. 비교 분석가
    var c8_tools: [str] = ["fetch-items", "extract-features", "compare-attributes", "summarize-differences"]
    agents.push(agent_spec_new("know-008", "Comparison Analyzer", "knowledge", "여러 항목 비교 분석", c8_tools, 5, false))

    ;; 9. 추천 엔진
    var c9_tools: [str] = ["analyze-preferences", "search-options", "rank-candidates", "explain-reasons"]
    agents.push(agent_spec_new("know-009", "Recommender", "knowledge", "사용자 선호도 기반 추천", c9_tools, 6, true))

    ;; 10. 지식 큐레이터
    var c10_tools: [str] = ["search-resources", "evaluate-quality", "organize-content", "create-collection"]
    agents.push(agent_spec_new("know-010", "Knowledge Curator", "knowledge", "고품질 지식 자료 수집 및 정리", c10_tools, 6, false))

    agents
}

