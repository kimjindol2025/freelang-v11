    agents.push(agent_spec_new("comm-007", "Feedback Collector", "comms", "사용자 피드백 수집 및 분석", d7_tools, 6, true))

    ;; 8. 긴급 알림 에이전트
    var d8_tools: [str] = ["detect-critical-event", "format-alert", "route-to-stakeholders", "log-incident"]
    agents.push(agent_spec_new("comm-008", "Alert Broadcaster", "comms", "긴급 상황 즉시 알림", d8_tools, 3, false))

    ;; 9. 다국어 메시지 번역기
    var d9_tools: [str] = ["detect-language", "translate-message", "localize-content", "send-translated"]
    agents.push(agent_spec_new("comm-009", "Multilingual Messenger", "comms", "다국어 메시지 번역 및 전송", d9_tools, 5, false))

    ;; 10. 광고 카피라이터
    var d10_tools: [str] = ["understand-product", "write-copy", "a-b-test-variants", "optimize-ctr"]
    agents.push(agent_spec_new("comm-010", "Copywriter", "comms", "마케팅 광고 카피 작성", d10_tools, 5, true))

    agents
}

;; ======== 카테고리 5: 운영 에이전트 (10개) ========

fn catalog_ops_agents() -> [AgentSpec] {
    var agents: [AgentSpec] = []

    ;; 1. 시스템 모니터
    var e1_tools: [str] = ["check-cpu", "check-memory", "check-disk", "check-network", "alert-if-critical"]
    agents.push(agent_spec_new("ops-001", "System Monitor", "ops", "시스템 리소스 모니터링 및 경고", e1_tools, 10, false))

    ;; 2. 로그 분석기
    var e2_tools: [str] = ["fetch-logs", "parse-logs", "detect-errors", "trend-analysis", "report-issues"]
    agents.push(agent_spec_new("ops-002", "Log Analyzer", "ops", "시스템 로그 분석 및 이상 탐지", e2_tools, 6, true))

    ;; 3. 작업 스케줄러
    var e3_tools: [str] = ["parse-schedule", "trigger-job", "monitor-execution", "retry-on-failure"]
    agents.push(agent_spec_new("ops-003", "Job Scheduler", "ops", "배치 작업 자동 스케줄링 및 실행", e3_tools, 8, false))

    ;; 4. 재시도 매니저
    var e4_tools: [str] = ["detect-failure", "exponential-backoff", "retry", "escalate-if-needed"]
    agents.push(agent_spec_new("ops-004", "Retry Manager", "ops", "실패한 작업 자동 재시도", e4_tools, 6, false))

    ;; 5. 배포 오케스트레이터
    var e5_tools: [str] = ["validate-deployment", "execute-rollout", "health-check", "rollback-if-needed"]
    agents.push(agent_spec_new("ops-005", "Deployment Orchestrator", "ops", "무중단 배포 자동화", e5_tools, 7, true))

    ;; 6. 백업 관리자
    var e6_tools: [str] = ["trigger-backup", "verify-backup", "test-restore", "cleanup-old-backups"]
    agents.push(agent_spec_new("ops-006", "Backup Manager", "ops", "자동 백업 및 복구 테스트", e6_tools, 5, false))

    ;; 7. 성능 최적화 에이전트
    var e7_tools: [str] = ["profile-system", "identify-bottlenecks", "apply-optimization", "measure-improvement"]
    agents.push(agent_spec_new("ops-007", "Performance Tuner", "ops", "시스템 성능 최적화", e7_tools, 7, true))

    ;; 8. 라이선스 관리자
    var e8_tools: [str] = ["inventory-software", "check-licenses", "alert-expiry", "renew-licenses"]
    agents.push(agent_spec_new("ops-008", "License Manager", "ops", "소프트웨어 라이선스 관리", e8_tools, 5, false))

    ;; 9. 비용 최적화 에이전트
    var e9_tools: [str] = ["analyze-costs", "identify-waste", "suggest-savings", "implement-optimization"]
    agents.push(agent_spec_new("ops-009", "Cost Optimizer", "ops", "클라우드 비용 최적화", e9_tools, 6, true))

    ;; 10. 규정 준수 감사
    var e10_tools: [str] = ["check-policies", "audit-practices", "find-violations", "suggest-remediation"]
    agents.push(agent_spec_new("ops-010", "Compliance Auditor", "ops", "규정 준수 자동 감시", e10_tools, 6, false))

    agents
}

// ==================== 카탈로그 관리 ====================

struct AgentCatalog {
    data_agents: [AgentSpec]
    code_agents: [AgentSpec]
    knowledge_agents: [AgentSpec]
    comms_agents: [AgentSpec]
    ops_agents: [AgentSpec]
    total_count: i32
}

fn catalog_build() -> AgentCatalog {
    var cat = AgentCatalog {
        data_agents: catalog_data_agents(),
        code_agents: catalog_code_agents(),
        knowledge_agents: catalog_knowledge_agents(),
        comms_agents: catalog_comms_agents(),
        ops_agents: catalog_ops_agents(),
        total_count: 50
    }
    cat
}

fn catalog_find_by_id(cat: AgentCatalog, id: str) -> AgentSpec {
    ;; 데이터 에이전트에서 검색
    var i: i32 = 0
    while i < length(cat.data_agents) {
        if cat.data_agents[i].id == id {
            return cat.data_agents[i]
        }
        i = i + 1
    }

    ;; 코드 에이전트에서 검색
    i = 0
    while i < length(cat.code_agents) {
        if cat.code_agents[i].id == id {
            return cat.code_agents[i]
        }
        i = i + 1
    }

    ;; 지식 에이전트에서 검색
    i = 0
    while i < length(cat.knowledge_agents) {
        if cat.knowledge_agents[i].id == id {
            return cat.knowledge_agents[i]
        }
        i = i + 1
    }

    ;; 커뮤니케이션 에이전트에서 검색
    i = 0
    while i < length(cat.comms_agents) {
        if cat.comms_agents[i].id == id {
            return cat.comms_agents[i]
        }
        i = i + 1
    }

    ;; 운영 에이전트에서 검색
    i = 0
    while i < length(cat.ops_agents) {
        if cat.ops_agents[i].id == id {
            return cat.ops_agents[i]
        }
        i = i + 1
    }

    ;; 찾지 못함 - 더미 반환
    agent_spec_new("not-found", "Not Found", "unknown", "Agent not found", [], 0, false)
}

fn catalog_list_by_category(cat: AgentCatalog, category: str) -> [AgentSpec] {
    var result: [AgentSpec] = []

    if category == "data" {
        result = cat.data_agents
    } else if category == "code" {
        result = cat.code_agents
    } else if category == "knowledge" {
        result = cat.knowledge_agents
    } else if category == "comms" {
        result = cat.comms_agents
    } else if category == "ops" {
        result = cat.ops_agents
    }

    result
}

// ==================== 메인 ====================

fn main() {
    println("╔═══════════════════════════════════════════╗")
    println("║  v9 Phase 2: 에이전트 카탈로그 (50개)    ║")
    println("╚═══════════════════════════════════════════╝")
    println("")

    var catalog = catalog_build()

    ;; 테스트 1: 데이터 에이전트
    println("✅ 테스트 1: 데이터 에이전트 (10개)")
    var i: i32 = 0
    while i < length(catalog.data_agents) {
        var agent = catalog.data_agents[i]
        println("  [" + agent.id + "] " + agent.name)
        i = i + 1
    }
    println("")

    ;; 테스트 2: 코드 에이전트
    println("✅ 테스트 2: 코드 에이전트 (10개)")
    i = 0
    while i < length(catalog.code_agents) {
        var agent = catalog.code_agents[i]
        println("  [" + agent.id + "] " + agent.name)
        i = i + 1
    }
    println("")

    ;; 테스트 3: ID로 검색
    println("✅ 테스트 3: ID로 에이전트 검색")
    var found = catalog_find_by_id(catalog, "know-001")
    agent_spec_print(found)

    ;; 테스트 4: 카테고리별 검색
    println("✅ 테스트 4: 카테고리별 에이전트 목록 (ops)")
    var ops_agents = catalog_list_by_category(catalog, "ops")
    println("  Found " + str(length(ops_agents)) + " agents")
    i = 0
    while i < length(ops_agents) {
        println("  [" + ops_agents[i].id + "] " + ops_agents[i].name)
        i = i + 1
    }
    println("")

    ;; 테스트 5: 통계
    println("✅ 테스트 5: 카탈로그 통계")
    println("  Total agents: " + str(catalog.total_count))
    println("  Data agents: " + str(length(catalog.data_agents)))
    println("  Code agents: " + str(length(catalog.code_agents)))
    println("  Knowledge agents: " + str(length(catalog.knowledge_agents)))
    println("  Communication agents: " + str(length(catalog.comms_agents)))
    println("  Operations agents: " + str(length(catalog.ops_agents)))
    println("")

    println("✅ 에이전트 카탈로그 (50개) 완성!")
}
