    agents.push(agent_spec_new("code-008", "API Doc Generator", "code", "REST API 문서 자동 생성", b8_tools, 5, false))

    ;; 9. 코드 마이그레이션 에이전트
    var b9_tools: [str] = ["analyze-legacy", "plan-migration", "transform-code", "validate-result"]
    agents.push(agent_spec_new("code-009", "Code Migrator", "code", "레거시 코드 현대화 및 마이그레이션", b9_tools, 8, true))

    ;; 10. 아키텍처 분석가
    var b10_tools: [str] = ["map-dependencies", "detect-issues", "suggest-improvements", "visualize"]
    agents.push(agent_spec_new("code-010", "Architecture Analyzer", "code", "시스템 아키텍처 분석 및 개선 제안", b10_tools, 6, true))

    agents
}

;; ======== 카테고리 3: 지식 에이전트 (10개) ========

fn catalog_knowledge_agents() -> [AgentSpec] {
    var agents: [AgentSpec] = []

    ;; 1. RAG 검색기
    var c1_tools: [str] = ["embed-query", "vector-search", "fetch-docs", "synthesize"]
    agents.push(agent_spec_new("know-001", "RAG Searcher", "knowledge", "벡터 검색 기반 지식 검색", c1_tools, 4, true))

    ;; 2. 요약가
    var c2_tools: [str] = ["fetch-document", "extract-key-points", "summarize", "highlight-insights"]
    agents.push(agent_spec_new("know-002", "Summarizer", "knowledge", "긴 문서 요약 및 핵심 포인트 추출", c2_tools, 5, false))

    ;; 3. 사실 검증기
    var c3_tools: [str] = ["extract-claims", "search-sources", "verify-facts", "report-findings"]
    agents.push(agent_spec_new("know-003", "Fact Checker", "knowledge", "주장 검증 및 거짓 정보 탐지", c3_tools, 6, true))

    ;; 4. 번역기
