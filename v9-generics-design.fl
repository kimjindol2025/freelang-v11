// FreeLang v9 제네릭/템플릿 설계 (컨셉)
// 향후 구현을 위한 설계 문서

;; 목표: 제네릭 타입 지원으로 코드 중복 제거

;; 현재 문제:
;; fn find_str(arr: [str], val: str) -> i32
;; fn find_int(arr: [i32], val: i32) -> i32
;; fn find_bool(arr: [bool], val: bool) -> i32

;; 제안 문법 (향후):
;; struct Node<T> {
;;     value: T
;;     next: i32
;; }
;;
;; fn find<T>(arr: [T], val: T) -> i32 {
;;     var i: i32 = 0
;;     while i < length(arr) {
;;         if arr[i] == val { return i }
;;         i = i + 1
;;     }
;;     return -1
;; }
;;
;; fn map<T, U>(arr: [T], mapper: fn(T) -> U) -> [U] {
;;     var result: [U] = []
;;     var i: i32 = 0
;;     while i < length(arr) {
;;         result.push(mapper(arr[i]))
;;         i = i + 1
;;     }
;;     result
