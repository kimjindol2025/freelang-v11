// FreeLang v9 표준 라이브러리 5: 도구 시스템
// 도구 등록, 실행, 검증

// ==================== 도구 정의 ====================

struct Tool {
    name: str
    description: str
    input_schema: [str]
    output_schema: str
    executable: bool
}

struct ToolRegistry {
    tools: [Tool]
    registry_size: i32
}

fn tool_new(name: str, description: str) -> Tool {
    Tool {
        name: name,
        description: description,
        input_schema: [],
        output_schema: "string",
        executable: true
    }
}

fn tool_add_input_schema(tool: Tool, input: str) -> Tool {
    tool.input_schema.push(input)
    tool
}

fn tool_registry_new() -> ToolRegistry {
    ToolRegistry {
        tools: [],
        registry_size: 0
    }
}

fn tool_registry_register(registry: ToolRegistry, tool: Tool) -> ToolRegistry {
    registry.tools.push(tool)
    registry.registry_size = registry.registry_size + 1

    println("[TOOLS] Registered: " + tool.name)
    println("  Description: " + tool.description)
    println("  Inputs: " + str(length(tool.input_schema)))

    registry
}

fn tool_registry_list(registry: ToolRegistry) -> [str] {
    var names: [str] = []
    var i: i32 = 0

    while i < length(registry.tools) {
        names.push(registry.tools[i].name)
        i = i + 1
    }

    names
}

fn tool_registry_get(registry: ToolRegistry, name: str) -> Tool {
    var i: i32 = 0

    while i < length(registry.tools) {
        if registry.tools[i].name == name {
            return registry.tools[i]
        }
        i = i + 1
    }

    ;; 도구 없음
    Tool {
        name: "not_found",
        description: "Tool not found",
        input_schema: [],
        output_schema: "error",
        executable: false
    }
}

// ==================== 도구 실행 ====================

struct ToolCall {
    tool_name: str
    arguments: [str]
    result: str
    status: str
    error_msg: str
}

fn tool_call_new(tool_name: str) -> ToolCall {
    ToolCall {
        tool_name: tool_name,
        arguments: [],
        result: "",
        status: "pending",
        error_msg: ""
    }
}

fn tool_call_add_arg(call: ToolCall, arg: str) -> ToolCall {
    call.arguments.push(arg)
    call
}

fn tool_call_execute(registry: ToolRegistry, call: ToolCall) -> ToolCall {
    println("[EXECUTE] Tool: " + call.tool_name)
    println("  Args: " + str(length(call.arguments)))

    var tool = tool_registry_get(registry, call.tool_name)

    if !tool.executable {
        call.status = "error"
        call.error_msg = "Tool not found or not executable"
        return call
    }

    ;; 기본 도구 실행 시뮬레이션
    if call.tool_name == "read-csv" {
        call.result = "CSV data loaded"
        call.status = "success"
    } else if call.tool_name == "write-json" {
        call.result = "JSON written"
        call.status = "success"
    } else if call.tool_name == "analyze-data" {
        call.result = "Analysis complete"
        call.status = "success"
    } else if call.tool_name == "call-api" {
        call.result = "API response received"
        call.status = "success"
    } else {
        call.result = "Tool executed"
        call.status = "success"
    }

    println("[RESULT] " + call.result)

    call
}

// ==================== 도구 체인 ====================

struct ToolChain {
    name: str
    tools: [ToolCall]
    results: [str]
}

fn tool_chain_new(name: str) -> ToolChain {
    ToolChain {
        name: name,
        tools: [],
        results: []
    }
}

fn tool_chain_add_call(chain: ToolChain, call: ToolCall) -> ToolChain {
    chain.tools.push(call)
    chain
}

fn tool_chain_execute(registry: ToolRegistry, chain: ToolChain) -> ToolChain {
    println("[CHAIN] Executing: " + chain.name)
    println("  Tools: " + str(length(chain.tools)))

    var i: i32 = 0
    while i < length(chain.tools) {
        println("  [" + str(i + 1) + "/" + str(length(chain.tools)) + "]")

        var call = chain.tools[i]
        call = tool_call_execute(registry, call)

        chain.results.push(call.result)

        i = i + 1
    }

    println("[CHAIN] Complete: " + str(length(chain.results)) + " results")

    chain
}

// ==================== 도구 검증 ====================

fn validate_tool(tool: Tool) -> bool {
    if length(tool.name) == 0 {
        return false
    }

    if length(tool.description) == 0 {
        return false
    }

    if !tool.executable {
        return false
    }

    true
}

fn validate_tool_call(call: ToolCall, tool: Tool) -> bool {
    if call.tool_name != tool.name {
        return false
    }

    if length(call.arguments) < length(tool.input_schema) {
        return false
    }

    true
}

// ==================== 메인 테스트 ====================

fn main() {
    println("╔═══════════════════════════════════════════╗")
    println("║  v9 표준 라이브러리 5: 도구 시스템        ║")
    println("╚═══════════════════════════════════════════╝")
    println("")

    ;; 테스트 1: 도구 레지스트리
    println("✅ 테스트 1: 도구 레지스트리")
    var registry = tool_registry_new()

    var tool1 = tool_new("read-csv", "Read CSV file")
    tool1 = tool_add_input_schema(tool1, "filename")
    tool1 = tool_add_input_schema(tool1, "encoding")
    registry = tool_registry_register(registry, tool1)

    var tool2 = tool_new("write-json", "Write JSON file")
    tool2 = tool_add_input_schema(tool2, "filename")
    tool2 = tool_add_input_schema(tool2, "data")
    registry = tool_registry_register(registry, tool2)

    var tool3 = tool_new("analyze-data", "Analyze data")
    tool3 = tool_add_input_schema(tool3, "data")
    registry = tool_registry_register(registry, tool3)

    println("  Registry size: " + str(registry.registry_size))
    println("")

    ;; 테스트 2: 도구 목록
    println("✅ 테스트 2: 도구 목록")
    var tool_names = tool_registry_list(registry)
    var i: i32 = 0
    while i < length(tool_names) {
        println("  - " + tool_names[i])
        i = i + 1
    }
    println("")

    ;; 테스트 3: 도구 검색
    println("✅ 테스트 3: 도구 검색")
    var found_tool = tool_registry_get(registry, "read-csv")
    println("  Found: " + found_tool.name)
    println("  Executable: " + str(found_tool.executable))
    println("")

    ;; 테스트 4: 도구 실행
    println("✅ 테스트 4: 도구 실행")
    var call1 = tool_call_new("read-csv")
    call1 = tool_call_add_arg(call1, "data.csv")
    call1 = tool_call_execute(registry, call1)
    println("  Status: " + call1.status)
    println("")

    ;; 테스트 5: 도구 체인
    println("✅ 테스트 5: 도구 체인")
    var chain = tool_chain_new("data-pipeline")

    var call2 = tool_call_new("read-csv")
    call2 = tool_call_add_arg(call2, "input.csv")
    chain = tool_chain_add_call(chain, call2)

    var call3 = tool_call_new("analyze-data")
    call3 = tool_call_add_arg(call3, "$data")
    chain = tool_chain_add_call(chain, call3)

    var call4 = tool_call_new("write-json")
    call4 = tool_call_add_arg(call4, "output.json")
    call4 = tool_call_add_arg(call4, "$result")
    chain = tool_chain_add_call(chain, call4)

    chain = tool_chain_execute(registry, chain)
    println("")

    ;; 테스트 6: 도구 검증
    println("✅ 테스트 6: 도구 검증")
    var is_valid = validate_tool(tool1)
    println("  tool1 valid: " + str(is_valid))

    var invalid_tool = tool_new("", "")
    var is_invalid = validate_tool(invalid_tool)
    println("  invalid_tool valid: " + str(is_invalid))
    println("")

    println("✅ v9 도구 시스템 라이브러리 완성!")
}
