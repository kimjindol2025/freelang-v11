;; L2 Proof Case 5: Function Definition and Closure
;; 함수 정의 및 클로저

(defn test-functions []
  (let [[add (fn [a b] (+ a b))]
        [double (fn [x] (* x 2))]]
    (println
      (list
        (add 3 4)           ; 7
        (double 5)          ; 10
        ((fn [x] (+ x 1)) 5)))))  ; 6
)

(test-functions)
