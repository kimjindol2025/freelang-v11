;; L2 Test 13: AI Library - Vector Operations
;; 벡터 연산 (덧셈, 내적, 크기)

(defun vector-add [v1 v2]
  (map (fn [i] (+ (get v1 i) (get v2 i)))
       (range 0 (length v1))))

(defun vector-dot [v1 v2]
  (reduce (fn [acc i]
    (+ acc (* (get v1 i) (get v2 i))))
   0
   (range 0 (length v1))))

(defun test-ai-vector []
  (let [[v1 [1 2 3]]
        [v2 [4 5 6]]]
    (console/log
      (list
        (vector-add v1 v2)      ; [5 7 9]
        (vector-dot v1 v2)))))  ; 32
)

(test-ai-vector)
