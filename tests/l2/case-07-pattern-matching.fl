;; L2 Proof Case 7: Type Checking & Predicates
;; 타입 검사 (null? list? map? string? number?)

(defun test-types []
  (console/log
    (list
      (null? null)          ; true
      (list? [1 2 3])       ; true
      (map? {:a 1})         ; true
      (string? "hello")     ; true
      (number? 42))))       ; true
)

(test-types)
