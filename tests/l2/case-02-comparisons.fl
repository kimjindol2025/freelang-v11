;; L2 Proof Case 2: Comparison Operations
;; 비교 연산 (= < > <= >= !=)

(defn test-comparisons []
  (println
    (list
      (= 5 5)        ; true
      (< 3 7)        ; true
      (> 10 4)       ; true
      (<= 5 5)       ; true
      (>= 6 2)       ; true
      (!= 3 3)))    ; false
)

(test-comparisons)
