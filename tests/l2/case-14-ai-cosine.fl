;; L2 Test 14: AI Library - Cosine Similarity
;; 코사인 유사도

(defun vector-dot [v1 v2]
  (reduce (fn [acc i] (+ acc (* (get v1 i) (get v2 i))))
   0
   (range 0 (length v1))))

(defun vector-magnitude [v]
  (math-sqrt (vector-dot v v)))

(defun cosine-sim [v1 v2]
  (let [[dot (vector-dot v1 v2)]
        [mag1 (vector-magnitude v1)]
        [mag2 (vector-magnitude v2)]]
    (if (or (= mag1 0) (= mag2 0))
      0
      (/ dot (* mag1 mag2)))))

(defun test-ai-cosine []
  (let [[v1 [1 0 0]]
        [v2 [0 1 0]]]
    (console/log (list (cosine-sim v1 v2)))))  ; 0 (직교)
)

(test-ai-cosine)
