;; L2 Proof Case 6: Collections (Array & Map)
;; 배열 및 맵 연산

(defn test-collections []
  (let [[arr [1 2 3]]
        [m {:x 10 :y 20}]]
    (println
      (list
        (get arr 0)           ; 1
        (get m :x)            ; 10
        (length arr)          ; 3
        (length (keys m))))))  ; 2

(test-collections)
