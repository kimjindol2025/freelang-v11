; L2 Proof Test 05: Functions & Closures
; defun, 익명함수, 고차함수

(defun add [a b]
  (+ a b))

(defun apply-twice [f x]
  (f (f x)))

(defun test-functions []
  (list
    (add 3 4)                ; 7
    ((fn [x] (* x 2)) 5)    ; 10
    (apply-twice (fn [x] (+ x 1)) 5)))  ; 7

(println (test-functions))
