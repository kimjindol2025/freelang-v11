; L2 Proof Test 02: Comparison Operations
; =, <, >, <=, >=, !=

(defun test-comparisons []
  (list
    (= 5 5)                  ; true
    (= 3 4)                  ; false
    (< 3 7)                  ; true
    (< 7 3)                  ; false
    (> 10 4)                 ; true
    (> 4 10)                 ; false
    (<= 5 5)                 ; true
    (<= 6 5)                 ; false
    (>= 6 2)                 ; true
    (>= 2 6)))               ; false

(println (test-comparisons))
