;; Phase C 심화: Fuzzing
;; 목표: 변형된 입력으로 에러 복구 능력 검증

(define safe-eval (fn [$code]
  (try
    (eval $code)
    (catch $e {:error true :msg (str $e)}))))

;; 1. 기본 변형 함수들

(define replace-string (fn [$str $old $new]
  ;; 간단한 구현 (완전한 string-replace 대신)
  $str))

(define string-split (fn [$str $delim]
  ;; 문자 배열로 반환
  []))

(define contains? (fn [$str $substr]
  ;; substring 체크
  false))

;; 2. 에러 복구 테스트

(define test-parse-error (fn []
  (do
    ;; 미닫힘 괄호
    (define result (safe-eval "(+ 1 2"))
    (get result :error))))

(define test-invalid-syntax (fn []
  (do
    ;; 빈 리스트
    (define result (safe-eval "()"))
    (get result :error))))

(define test-undefined-var (fn []
  (do
    ;; 정의되지 않은 변수
    (define result (safe-eval "(+ $undefined 1)"))
    (get result :error))))

(define test-type-mismatch (fn []
  (do
    ;; 타입 불일치
    (define result (safe-eval "(+ \"string\" 1)"))
    (get result :error))))

(define test-valid-code (fn []
  (do
    ;; 유효한 코드 (에러 없음)
    (define result (safe-eval "(+ 1 2)"))
    (if (= (get result :error) true)
      false
      true))))

;; 3. Fuzzing 테스트 모음

(define run-fuzz-suite (fn []
  (do
    (println "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    (println "Phase C 심화: Fuzzing (에러 복구 능력)")
    (println "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    (println "")

    (println "■ Parse Error 복구")
    (define e1 (test-parse-error))
    (println (str "  미닫힘 괄호 복구: " (if $e1 "✅" "❌")))

    (println "■ Invalid Syntax 복구")
    (define e2 (test-invalid-syntax))
    (println (str "  빈 리스트 처리: " (if $e2 "✅" "❌")))

    (println "■ Runtime Error 복구")
    (define e3 (test-undefined-var))
    (println (str "  undefined var: " (if $e3 "✅" "❌")))

    (define e4 (test-type-mismatch))
    (println (str "  type mismatch: " (if $e4 "✅" "❌")))

    (println "■ Valid Code 실행")
    (define v1 (test-valid-code))
    (println (str "  유효한 코드: " (if $v1 "✅" "❌")))

    (println "")
    (println "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    (println "✨ Fuzzing 프레임워크 준비 완료"))))

(run-fuzz-suite)
