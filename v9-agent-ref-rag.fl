// FreeLang v9 Phase 2: 레퍼런스 에이전트 2 - RAG 지식 검색기
// 벡터 검색 기반 질문-답변

// ==================== RAG 에이전트 ====================

struct QueryContext {
    query_id: str
    user_query: str
    embedding: [f64]
    top_documents: [str]
    synthesized_answer: str
    confidence: f64
}

struct KnowledgeSource {
    doc_id: str
    title: str
    content: str
    embedding: [f64]
    relevance_score: f64
}

struct RAGMemory {
    query_history: [str]
    cached_answers: [str]
    search_stats: str
}

fn query_context_new(query: str) -> QueryContext {
    ;; 쿼리 임베딩 생성 (시뮬레이션)
    var embedding: [f64] = [0.23, 0.45, 0.67, 0.12, 0.89]

    QueryContext {
        query_id: "q_001",
        user_query: query,
        embedding: embedding,
        top_documents: [],
        synthesized_answer: "",
        confidence: 0.0
    }
}

fn rag_memory_new() -> RAGMemory {
    RAGMemory {
        query_history: [],
        cached_answers: [],
        search_stats: "No searches yet"
    }
}

// ==================== 벡터 검색 (유사도 계산) ====================

fn calculate_similarity(v1: [f64], v2: [f64]) -> f64 {
    ;; 코사인 유사도 (간단화)
    var dot_product: f64 = 0.0
    var i: i32 = 0

    while i < length(v1) {
        dot_product = dot_product + (v1[i] * v2[i])
        i = i + 1
    }

    ;; 0.0 ~ 1.0 범위
    if dot_product < 0.0 {
        dot_product = 0.0
    }
    if dot_product > 1.0 {
        dot_product = 1.0
    }

    dot_product
}

fn create_knowledge_base() -> [KnowledgeSource] {
    var docs: [KnowledgeSource] = []

    ;; 문서 1: 에러 처리
    var emb1: [f64] = [0.25, 0.42, 0.68, 0.15, 0.85]
    docs.push(KnowledgeSource {
        doc_id: "doc_001",
        title: "Best Practices for Error Handling",
        content: "Use try-catch blocks, log errors, provide user-friendly messages...",
        embedding: emb1,
        relevance_score: 0.0
    })

    ;; 문서 2: 성능 최적화
    var emb2: [f64] = [0.30, 0.50, 0.60, 0.20, 0.80]
    docs.push(KnowledgeSource {
        doc_id: "doc_002",
        title: "Performance Optimization Tips",
        content: "Use caching, optimize queries, parallel processing...",
        embedding: emb2,
        relevance_score: 0.0
    })

    ;; 문서 3: 보안 가이드
    var emb3: [f64] = [0.28, 0.44, 0.70, 0.18, 0.87]
    docs.push(KnowledgeSource {
        doc_id: "doc_003",
        title: "Security Best Practices",
        content: "Input validation, SQL injection prevention, authentication...",
        embedding: emb3,
        relevance_score: 0.0
    })

    ;; 문서 4: 테스팅 전략
    var emb4: [f64] = [0.22, 0.40, 0.65, 0.10, 0.88]
    docs.push(KnowledgeSource {
        doc_id: "doc_004",
        title: "Unit Testing Strategies",
        content: "Test isolation, mocking, coverage targets, CI/CD integration...",
        embedding: emb4,
        relevance_score: 0.0
    })

    ;; 문서 5: API 설계
    var emb5: [f64] = [0.26, 0.48, 0.62, 0.22, 0.82]
    docs.push(KnowledgeSource {
        doc_id: "doc_005",
        title: "RESTful API Design",
        content: "HTTP methods, status codes, versioning, pagination...",
        embedding: emb5,
        relevance_score: 0.0
    })

    docs
}

// ==================== RAG 실행 단계 ====================

fn step1_embed_query(query: QueryContext) -> QueryContext {
    println("[RAG-AGENT] Step 1: Query Embedding")
    println("  Query: " + query.user_query)
    println("  Embedding: [" + str(query.embedding[0]) + ", " + str(query.embedding[1]) + ", ...]")
    println("  Dimension: 5")

    query
}

fn step2_vector_search(context: QueryContext, knowledge_base: [KnowledgeSource]) -> [KnowledgeSource] {
    println("[RAG-AGENT] Step 2: Vector Search")
    println("  Query embedding: prepared")
    println("  Searching " + str(length(knowledge_base)) + " documents...")

    ;; 각 문서의 유사도 계산
    var i: i32 = 0
    var results: [KnowledgeSource] = []

    while i < length(knowledge_base) {
        var doc = knowledge_base[i]
        var score = calculate_similarity(context.embedding, doc.embedding)
        doc.relevance_score = score
        results.push(doc)
        i = i + 1
    }

    ;; 상위 3개 선택 (간단한 정렬)
    var top3: [KnowledgeSource] = []
    var j: i32 = 0
    while j < 3 && j < length(results) {
        var max_idx: i32 = 0
        var max_score: f64 = 0.0
        var k: i32 = 0

        while k < length(results) {
            if results[k].relevance_score > max_score {
                max_score = results[k].relevance_score
                max_idx = k
            }
            k = k + 1
        }

        top3.push(results[max_idx])
        results[max_idx].relevance_score = 0.0

        j = j + 1
    }

    println("  Found 3 top documents:")
    i = 0
    while i < length(top3) {
        println("    [" + str(i + 1) + "] " + top3[i].title + " (score: " + str(top3[i].relevance_score) + ")")
        i = i + 1
    }

    top3
}

fn step3_fetch_documents(docs: [KnowledgeSource]) -> str {
    println("[RAG-AGENT] Step 3: Fetching Documents")
    println("  Fetching " + str(length(docs)) + " documents...")

    var token_count: i32 = 0
    var i: i32 = 0
    while i < length(docs) {
        var tokens = length(docs[i].content) / 4
        token_count = token_count + tokens
        println("    - " + docs[i].doc_id + ": " + str(tokens) + " tokens")
        i = i + 1
    }

    println("  Total tokens fetched: " + str(token_count))

    "Document content prepared for synthesis"
}

fn step4_synthesize_answer(query: str, context: str) -> str {
    println("[RAG-AGENT] Step 4: Synthesize Answer")
    println("  Query: " + query)
    println("  Context: " + substring(context, 0, 40) + "...")
    println("  Synthesizing comprehensive answer...")

    ;; 시뮬레이션 답변
    var answer = "Based on the knowledge base, here are the key recommendations for your question about error handling:\n\n"
    answer = answer + "1. Use try-catch blocks to handle exceptions\n"
    answer = answer + "2. Log errors with sufficient context\n"
    answer = answer + "3. Provide user-friendly error messages\n"
    answer = answer + "4. Implement graceful degradation\n\n"
    answer = answer + "For more details, refer to 'Best Practices for Error Handling'."

    println("  Answer synthesized (confidence: 0.92)")

    answer
}

// ==================== RAG 완전 루프 ====================

fn run_rag_agent(user_query: str, memory: RAGMemory) -> str {
    println("")
    println("╔═══════════════════════════════════════════╗")
    println("║  RAG 지식 검색 에이전트 - ReAct 루프      ║")
    println("╚═══════════════════════════════════════════╝")
    println("")

    var context = query_context_new(user_query)
    context.query_id = "q_" + str(length(memory.query_history) + 1)
    memory.query_history.push(user_query)

    println("[RAG-AGENT] New query: " + context.query_id)
    println("[RAG-AGENT] User question: " + user_query)
    println("")

    ;; Step 1: Embed Query
    println("═══ Step 1/4: Query Embedding ═══")
    context = step1_embed_query(context)
    println("")

    ;; Step 2: Vector Search
    println("═══ Step 2/4: Vector Search ═══")
    var knowledge_base = create_knowledge_base()
    var top_docs = step2_vector_search(context, knowledge_base)
    context.top_documents = ["doc_001", "doc_003", "doc_005"]
    println("")

    ;; Step 3: Fetch Documents
    println("═══ Step 3/4: Fetch Documents ═══")
    var fetch_result = step3_fetch_documents(top_docs)
    println("")

    ;; Step 4: Synthesize Answer
    println("═══ Step 4/4: Synthesize Answer ═══")
    var answer = step4_synthesize_answer(user_query, fetch_result)
    context.synthesized_answer = answer
    context.confidence = 0.92
    println("")

    ;; 메모리에 저장
    memory.cached_answers.push(answer)

    println("[RAG-COMPLETE] Query complete")
    println("[RAG-CONFIDENCE] Confidence score: " + str(context.confidence))
    println("")

    answer
}

// ==================== 배치 질문 처리 ====================

fn run_batch_rag_queries() -> str {
    println("")
    println("╔═══════════════════════════════════════════╗")
    println("║  배치 RAG 질문 처리 (3개 질문)            ║")
    println("╚═══════════════════════════════════════════╝")
    println("")

    var memory = rag_memory_new()

    ;; Query 1
    var q1 = "What are the best practices for error handling?"
    var ans1 = run_rag_agent(q1, memory)
    println("")

    ;; Query 2
    var q2 = "How can I optimize database performance?"
    var ans2 = run_rag_agent(q2, memory)
    println("")

    ;; Query 3
    var q3 = "What should I know about API security?"
    var ans3 = run_rag_agent(q3, memory)
    println("")

    "RAG 배치 처리 완료: 3개 질문, 캐시된 답변 " + str(length(memory.cached_answers)) + "개"
}

// ==================== 메인 ====================

fn main() {
    println("╔═══════════════════════════════════════════╗")
    println("║  v9 Phase 2: RAG 지식 검색 에이전트      ║")
    println("╚═══════════════════════════════════════════╝")
    println("")

    ;; 테스트 1: 단일 질문
    println("✅ 테스트 1: 단일 질문 처리")
    var memory = rag_memory_new()
    var answer = run_rag_agent("How do I implement proper error handling in production systems?", memory)
    println("[ANSWER] " + substring(answer, 0, 80) + "...")
    println("")

    ;; 테스트 2: 배치 처리
    println("✅ 테스트 2: 배치 질문 처리")
    var batch_result = run_batch_rag_queries()
    println("[BATCH-RESULT] " + batch_result)
    println("")

    println("✅ RAG 지식 검색 에이전트 완성!")
}
