    ;; 구조체 정의
    var col = Column {
        name: "id",
        data_type: "integer",
        nullable: false,
        primary_key: true
    }

    println("✅ Struct: Column")
    println("  - name: " + col.name)
    println("  - data_type: " + col.data_type)
    println("  - primary_key: " + (if col.primary_key { "true" } else { "false" }))

    println("")
}

// ==================== 통합 테스트 10: 전체 3계층 ====================

fn test_full_architecture() {
    println("╔═══════════════════════════════════════════╗")
    println("║  TEST 10: 전체 3계층 아키텍처            ║")
    println("╚═══════════════════════════════════════════╝")

    println("📊 3계층 통합 테스트 시작...")
    println("")

    ;; 1. Storage Layer (B-Tree)
    println("1️⃣ Storage Layer (B-Tree)")
    var btree = btree_new("users_index", 4)
    var i: i32 = 0
    while i < 20 {
        btree = btree_insert(btree, "City" + str(i), i)
        i = i + 1
    }
    var btree_search = btree_search(btree, "City10")
    println("   ✅ B-Tree search: " + str(length(btree_search)) + " rows")

    ;; 2. Engine Layer (Cache + Plan)
    println("2️⃣ Engine Layer (Cache + Optimization)")
    var cache = query_cache_new(10)
    var plan = create_query_plan("users", true)
    cache = query_cache_put(cache, "Q1", ["row1"])
    var cached = query_cache_get(cache, "Q1")
    println("   ✅ Cache hit: " + str(length(cached)) + " rows")
    println("   ✅ Query plan: " + plan.plan_type)

    ;; 3. API Layer (SQL)
    println("3️⃣ API Layer (SQL Parsing)")
    var sql = "SELECT * FROM users WHERE city='Seoul'"
    if !is_sql_injection_detected(sql) {
        println("   ✅ SQL validation passed")
    }

    println("")
    println("✅ 전체 3계층 통합 테스트 완료!")
    println("")
}

