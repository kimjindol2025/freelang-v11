{"id":"T150_combo_pipeline_long","category":"data-transform","difficulty":"hard","prompt":"users [{:n \"a\" :s 80} {:n \"b\" :s 95} {:n \"c\" :s 60}]에서 80점 이상 학생 이름들 join. 결과: \"a,b\".","validation":{"type":"stdout_contains","expected":"a,b"},"reference_solution":"(let [[us (list {:n \"a\" :s 80} {:n \"b\" :s 95} {:n \"c\" :s 60})] [pass (filter (fn [u] (>= (get u :s) 80)) us)] [names (map (fn [u] (get u :n)) pass)]] (println (str_join \",\" names)))","tags":["filter","map","str_join"]}
