{"id":"T182_state_loop","category":"state-machine","difficulty":"medium","prompt":"이벤트 [:start :run :run :stop]을 reduce로 적용. start→running, run→running, stop→idle. 결과 \"idle\".","validation":{"type":"stdout_contains","expected":"idle"},"reference_solution":"(println (reduce (fn [s e] (cond [(= e :start) \"running\"] [(= e :run) \"running\"] [(= e :stop) \"idle\"] [true s])) \"init\" (list :start :run :run :stop)))","tags":["reduce","state"]}
