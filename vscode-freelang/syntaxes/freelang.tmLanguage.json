{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "FreeLang",
  "scopeName": "source.fl",
  "fileTypes": ["fl"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#block-macros" },
    { "include": "#special-forms" },
    { "include": "#builtin-db" },
    { "include": "#builtin-server" },
    { "include": "#builtin-auth" },
    { "include": "#builtin-core" },
    { "include": "#keywords" },
    { "include": "#variables" },
    { "include": "#numbers" },
    { "include": "#booleans" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.semicolon.fl", "match": ";;.*$" },
        { "name": "comment.line.semicolon.fl", "match": ";.*$" },
        { "name": "comment.block.fl", "begin": "#\\|", "end": "\\|#" }
      ]
    },
    "strings": {
      "name": "string.quoted.double.fl",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.fl", "match": "\\\\." }
      ]
    },
    "block-macros": {
      "patterns": [
        {
          "name": "keyword.control.block.fl",
          "match": "\\[(FUNC|LAYOUT|COMPONENT|PAGE|ROUTE|API|SERVICE|CONTROLLER|GUARD|MIDDLEWARE|IMPORT|EXPORT|MODULE|INTENT|COT|AGENT|EVOLVE|WISDOM|PLAN|OBSERVE|ANALYZE|DECIDE|ACT|VERIFY|SEARCH|LEARN|REASONING|TRY|CATCH)\\b"
        }
      ]
    },
    "special-forms": {
      "patterns": [
        {
          "name": "keyword.control.fl",
          "match": "\\b(defn|define|defmacro|defprotocol|defstruct|let|if|when|unless|cond|case|match|do|fn|lambda|and|or|not|try|catch|throw|quote|unquote|quasiquote|loop|recur|for|while|return)\\b"
        }
      ]
    },
    "builtin-db": {
      "patterns": [
        {
          "name": "support.function.db.fl",
          "match": "\\b(db_query|db_exec|db_insert|db_update|db_delete_row|db_create|db_get|db_all|db_put|db_delete|db_count|db_tables)\\b"
        }
      ]
    },
    "builtin-server": {
      "patterns": [
        {
          "name": "support.function.server.fl",
          "match": "\\b(server_get|server_post|server_put|server_delete|server_patch|server_start|server_stop|server_json|server_html|server_text|server_status|server_req_body|server_req_param|server_req_query|server_req_header|server_wait_respond)\\b"
        }
      ]
    },
    "builtin-auth": {
      "patterns": [
        {
          "name": "support.function.auth.fl",
          "match": "\\b(auth_jwt_sign|auth_jwt_verify|auth_jwt_decode|auth_jwt_expired|auth_hash_password|auth_verify_password|auth_bearer_extract|auth_hmac|auth_random_token|auth_apikey_valid|auth_apikey_get)\\b"
        }
      ]
    },
    "builtin-core": {
      "patterns": [
        {
          "name": "support.function.core.fl",
          "match": "\\b(println|print|str|concat|get|set|first|last|rest|length|count|map|filter|reduce|range|keys|values|pairs|json_parse|json_stringify|json_str|json_get|json_set|json_has|json_keys|json_vals|json_merge|now_unix|now_iso|now_ms|env_get|env_require|sha256|hmac_sha256|uuid_v4|uuid_short|random_int|validate_email|validate_regex|validate_number|replace|regex_replace|regex_match|split|substring|trim|str_trim|str_template|lowercase|uppercase)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "constant.other.keyword.fl",
          "match": ":[a-zA-Z_][a-zA-Z0-9_\\-]*"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.dollar.fl",
          "match": "\\$[a-zA-Z_][a-zA-Z0-9_\\-\\?!]*"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.fl",
          "match": "-?\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        { "name": "constant.language.boolean.fl", "match": "\\b(true|false|nil|null)\\b" }
      ]
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.definition.list.fl", "match": "[\\(\\)]" },
        { "name": "punctuation.definition.block.fl", "match": "[\\[\\]]" },
        { "name": "punctuation.definition.map.fl", "match": "[\\{\\}]" }
      ]
    }
  }
}
