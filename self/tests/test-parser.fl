;; P03/44 smoke: lexer → parser → AST 구조 검증.

;; lexer (간소화) + parser 전체 재수록.
;; 큰 파일이지만 smoke 를 독립 실행하려면 불가피.

;; ─── Lexer ───────────────────────────
[FUNC is-digit? :params [$c] :body (if (null? $c) false (and (>= $c "0") (<= $c "9")))]
[FUNC is-alpha? :params [$c]
  :body (if (null? $c) false
          (or (and (>= $c "a") (<= $c "z")) (and (>= $c "A") (<= $c "Z"))))]
[FUNC is-alnum? :params [$c] :body (or (is-digit? $c) (is-alpha? $c))]
[FUNC is-space? :params [$c] :body (or (= $c " ") (= $c "\t") (= $c "\n") (= $c "\r"))]
[FUNC is-symbol-char? :params [$c]
  :body (if (null? $c) false
          (or (is-alnum? $c) (= $c "-") (= $c "_") (= $c "?") (= $c "!")
              (= $c "/") (= $c ".") (= $c "<") (= $c ">") (= $c "=")
              (= $c "+") (= $c "*") (= $c "%") (= $c "&") (= $c "|") (= $c "^")))]

[FUNC make-state :params [$src] :body {:src $src :idx 0 :line 1 :col 1 :tokens []}]
[FUNC peek-at :params [$st $o]
  :body (let [[$s (get $st :src)] [$i (+ (get $st :idx) $o)]]
          (if (>= $i (length $s)) null (char-at $s $i)))]
[FUNC peek :params [$st] :body (peek-at $st 0)]
[FUNC at-end? :params [$st] :body (>= (get $st :idx) (length (get $st :src)))]
[FUNC advance :params [$st]
  :body (let [[$c (peek $st)]]
          (if (= $c "\n")
            {:src (get $st :src) :idx (+ (get $st :idx) 1) :line (+ (get $st :line) 1) :col 1 :tokens (get $st :tokens)}
            {:src (get $st :src) :idx (+ (get $st :idx) 1) :line (get $st :line) :col (+ (get $st :col) 1) :tokens (get $st :tokens)}))]
[FUNC emit :params [$st $k $v $sl $sc]
  :body {:src (get $st :src) :idx (get $st :idx) :line (get $st :line) :col (get $st :col)
         :tokens (append (get $st :tokens) (list {:kind $k :value $v :line $sl :col $sc}))}]
[FUNC skip-comment :params [$st]
  :body (if (at-end? $st) $st
          (let [[$c (peek $st)]]
            (if (= $c "\n") (advance $st) (skip-comment (advance $st)))))]
[FUNC skip-ws :params [$st]
  :body (if (at-end? $st) $st
          (let [[$c (peek $st)]]
            (cond [(is-space? $c) (skip-ws (advance $st))]
                  [(= $c ";") (skip-ws (skip-comment $st))]
                  [true $st])))]
[FUNC read-number-body :params [$st $a $d $l $c]
  :body (if (at-end? $st) (emit $st "Number" $a $l $c)
          (let [[$ch (peek $st)]]
            (cond [(is-digit? $ch) (read-number-body (advance $st) (str $a $ch) $d $l $c)]
                  [(and (= $ch ".") (not $d)) (read-number-body (advance $st) (str $a $ch) true $l $c)]
                  [true (emit $st "Number" $a $l $c)])))]
[FUNC read-number :params [$st] :body (read-number-body $st "" false (get $st :line) (get $st :col))]
[FUNC translate-esc :params [$c]
  :body (cond [(= $c "n") "\n"] [(= $c "t") "\t"] [(= $c "\"") "\""] [(= $c "\\") "\\"] [true $c])]
[FUNC read-string-body :params [$st $a $l $c]
  :body (if (at-end? $st) (emit $st "String" $a $l $c)
          (let [[$ch (peek $st)]]
            (cond [(= $ch "\"") (emit (advance $st) "String" $a $l $c)]
                  [(= $ch "\\")
                   (let [[$s2 (advance $st)] [$c2 (peek $s2)]]
                     (read-string-body (advance $s2) (str $a (translate-esc $c2)) $l $c))]
                  [true (read-string-body (advance $st) (str $a $ch) $l $c)])))]
[FUNC read-string :params [$st]
  :body (let [[$l (get $st :line)] [$c (get $st :col)] [$s1 (advance $st)]]
          (read-string-body $s1 "" $l $c))]
[FUNC read-sym-body :params [$st $a $l $c $k]
  :body (if (at-end? $st) (emit $st $k $a $l $c)
          (let [[$ch (peek $st)]]
            (if (is-symbol-char? $ch) (read-sym-body (advance $st) (str $a $ch) $l $c $k)
              (emit $st $k $a $l $c))))]
[FUNC read-symbol :params [$st] :body (read-sym-body $st "" (get $st :line) (get $st :col) "Symbol")]
[FUNC read-variable :params [$st]
  :body (let [[$l (get $st :line)] [$c (get $st :col)] [$s1 (advance $st)]]
          (read-sym-body $s1 "" $l $c "Variable"))]
[FUNC read-keyword :params [$st]
  :body (let [[$l (get $st :line)] [$c (get $st :col)] [$s1 (advance $st)]]
          (read-sym-body $s1 "" $l $c "Keyword"))]
[FUNC read-token :params [$st]
  :body (let [[$s1 (skip-ws $st)]]
          (if (at-end? $s1) $s1
            (let [[$c (peek $s1)] [$l (get $s1 :line)] [$col (get $s1 :col)]]
              (cond
                [(= $c "(") (emit (advance $s1) "LParen" $c $l $col)]
                [(= $c ")") (emit (advance $s1) "RParen" $c $l $col)]
                [(= $c "[") (emit (advance $s1) "LBracket" $c $l $col)]
                [(= $c "]") (emit (advance $s1) "RBracket" $c $l $col)]
                [(= $c "{") (emit (advance $s1) "LBrace" $c $l $col)]
                [(= $c "}") (emit (advance $s1) "RBrace" $c $l $col)]
                [(= $c "\"") (read-string $s1)]
                [(= $c "$") (read-variable $s1)]
                [(= $c ":") (read-keyword $s1)]
                [(is-digit? $c) (read-number $s1)]
                [(and (= $c "-") (is-digit? (peek-at $s1 1)))
                 (read-number-body (advance $s1) "-" false $l $col)]
                [(is-symbol-char? $c) (read-symbol $s1)]
                [true (emit (advance $s1) "Unknown" $c $l $col)]))))]
[FUNC lex-loop :params [$st]
  :body (let [[$s1 (skip-ws $st)]]
          (if (at-end? $s1) (get $s1 :tokens) (lex-loop (read-token $s1))))]
[FUNC lex :params [$src] :body (lex-loop (make-state $src))]

;; ─── AST ─────────────────────────────
[FUNC make-literal :params [$t $v $l] :body {:kind "literal" :type $t :value $v :line $l}]
[FUNC make-variable :params [$n $l] :body {:kind "variable" :name $n :line $l}]
[FUNC make-keyword :params [$n $l] :body {:kind "keyword" :name $n :line $l}]
[FUNC make-sexpr :params [$op $args $l] :body {:kind "sexpr" :op $op :args $args :line $l}]
[FUNC make-array-block :params [$items $l] :body {:kind "block" :type "Array" :name null :fields {:items $items} :line $l}]
[FUNC make-map-block :params [$items $l] :body {:kind "block" :type "Map" :name null :fields {:items $items} :line $l}]
[FUNC make-block :params [$t $n $f $l] :body {:kind "block" :type $t :name $n :fields $f :line $l}]

;; ─── Parser ──────────────────────────
[FUNC p-make :params [$tokens] :body {:tokens $tokens :idx 0 :ast []}]
[FUNC p-peek :params [$p]
  :body (let [[$i (get $p :idx)] [$t (get $p :tokens)]]
          (if (>= $i (length $t)) null (get $t $i)))]
[FUNC p-peek-at :params [$p $o]
  :body (let [[$i (+ (get $p :idx) $o)] [$t (get $p :tokens)]]
          (if (>= $i (length $t)) null (get $t $i)))]
[FUNC p-end? :params [$p] :body (>= (get $p :idx) (length (get $p :tokens)))]
[FUNC p-advance :params [$p] :body {:tokens (get $p :tokens) :idx (+ (get $p :idx) 1) :ast (get $p :ast)}]
[FUNC p-with-ast :params [$p $a] :body {:tokens (get $p :tokens) :idx (get $p :idx) :ast $a}]
[FUNC p-append-ast :params [$p $n] :body (p-with-ast $p (append (get $p :ast) (list $n)))]
[FUNC r-pair :params [$p $n] :body {:p $p :node $n}]

[FUNC parse-atom :params [$p]
  :body (let [[$t (p-peek $p)] [$k (get $t :kind)] [$v (get $t :value)] [$l (get $t :line)]]
          (cond
            [(= $k "Number") (r-pair (p-advance $p) (make-literal "number" $v $l))]
            [(= $k "String") (r-pair (p-advance $p) (make-literal "string" $v $l))]
            [(= $k "Symbol") (r-pair (p-advance $p) (make-literal "symbol" $v $l))]
            [(= $k "Variable") (r-pair (p-advance $p) (make-variable $v $l))]
            [(= $k "Keyword") (r-pair (p-advance $p) (make-keyword $v $l))]
            [true (r-pair (p-advance $p) (make-literal "unknown" $v $l))]))]

[FUNC parse-expr :params [$p]
  :body (let [[$t (p-peek $p)] [$k (get $t :kind)]]
          (cond
            [(= $k "LParen") (parse-sexpr $p)]
            [(= $k "LBracket") (parse-bracket $p)]
            [(= $k "LBrace") (parse-map $p)]
            [true (parse-atom $p)]))]

[FUNC parse-args :params [$p $acc]
  :body (let [[$t (p-peek $p)]]
          (cond
            [(null? $t) (r-pair $p $acc)]
            [(= (get $t :kind) "RParen") (r-pair $p $acc)]
            [(= (get $t :kind) "RBracket") (r-pair $p $acc)]
            [(= (get $t :kind) "RBrace") (r-pair $p $acc)]
            [true (let [[$one (parse-expr $p)]]
                    (parse-args (get $one :p) (append $acc (list (get $one :node)))))]))]

[FUNC parse-consume-rparen :params [$p]
  :body (let [[$t (p-peek $p)]]
          (if (and (not (null? $t)) (= (get $t :kind) "RParen")) (p-advance $p) $p))]

[FUNC parse-sexpr :params [$p]
  :body (let [[$tok (p-peek $p)] [$line (get $tok :line)] [$p1 (p-advance $p)]
              [$coll (parse-args $p1 [])] [$p2 (get $coll :p)] [$args (get $coll :node)]]
          (if (= (length $args) 0)
            (r-pair (parse-consume-rparen $p2) (make-sexpr "" (list) $line))
            (let [[$op-n (get $args 0)]
                  [$op (cond [(= (get $op-n :kind) "literal") (get $op-n :value)]
                             [(= (get $op-n :kind) "variable") (str "$" (get $op-n :name))]
                             [true "unknown"])]
                  [$rest (slice $args 1 (length $args))]]
              (r-pair (parse-consume-rparen $p2) (make-sexpr $op $rest $line)))))]

[FUNC parse-consume-rbracket :params [$p]
  :body (let [[$t (p-peek $p)]]
          (if (and (not (null? $t)) (= (get $t :kind) "RBracket")) (p-advance $p) $p))]

[FUNC parse-consume-rbrace :params [$p]
  :body (let [[$t (p-peek $p)]]
          (if (and (not (null? $t)) (= (get $t :kind) "RBrace")) (p-advance $p) $p))]

[FUNC is-block-type? :params [$s]
  :body (let [[$c (char-at $s 0)]] (and (>= $c "A") (<= $c "Z")))]

[FUNC parse-optional-name :params [$p]
  :body (let [[$t (p-peek $p)]]
          (if (and (not (null? $t))
                   (= (get $t :kind) "Symbol")
                   (not (= (char-at (get $t :value) 0) ":")))
            (r-pair (p-advance $p) (get $t :value))
            (r-pair $p null)))]

[FUNC parse-block-fields :params [$p $acc]
  :body (let [[$t (p-peek $p)]]
          (cond
            [(null? $t) (r-pair $p $acc)]
            [(= (get $t :kind) "RBracket") (r-pair $p $acc)]
            [(= (get $t :kind) "Keyword")
             (let [[$key (get $t :value)] [$p1 (p-advance $p)]
                   [$val (parse-expr $p1)] [$p2 (get $val :p)] [$v (get $val :node)]]
               (parse-block-fields $p2 (json_set $acc $key $v)))]
            [true (r-pair (p-advance $p) $acc)]))]

[FUNC parse-named-block :params [$p $line]
  :body (let [[$tt (p-peek $p)] [$type (get $tt :value)] [$p1 (p-advance $p)]
              [$ni (parse-optional-name $p1)] [$p2 (get $ni :p)] [$name (get $ni :node)]
              [$fi (parse-block-fields $p2 {})] [$p3 (get $fi :p)] [$fields (get $fi :node)]]
          (r-pair (parse-consume-rbracket $p3) (make-block $type $name $fields $line)))]

[FUNC parse-array :params [$p $line]
  :body (let [[$coll (parse-args $p [])] [$p2 (get $coll :p)] [$items (get $coll :node)]]
          (r-pair (parse-consume-rbracket $p2) (make-array-block $items $line)))]

[FUNC parse-bracket :params [$p]
  :body (let [[$tok (p-peek $p)] [$line (get $tok :line)] [$p1 (p-advance $p)]
              [$next (p-peek $p1)]]
          (if (and (not (null? $next))
                   (= (get $next :kind) "Symbol")
                   (is-block-type? (get $next :value)))
            (parse-named-block $p1 $line)
            (parse-array $p1 $line)))]

[FUNC parse-map :params [$p]
  :body (let [[$tok (p-peek $p)] [$line (get $tok :line)] [$p1 (p-advance $p)]
              [$coll (parse-args $p1 [])] [$p2 (get $coll :p)] [$items (get $coll :node)]]
          (r-pair (parse-consume-rbrace $p2) (make-map-block $items $line)))]

[FUNC parse-all :params [$p]
  :body (if (p-end? $p)
          (get $p :ast)
          (let [[$one (parse-expr $p)]
                [$p2 (p-append-ast (get $one :p) (get $one :node))]]
            (parse-all $p2)))]

[FUNC parse :params [$tokens] :body (parse-all (p-make $tokens))]

;; ─── smoke ───────────────────────────

[FUNC ast-summary :params [$nodes]
  :body (reduce (fn [$acc $n]
                  (cond
                    [(= (get $n :kind) "sexpr")
                     (str $acc "sexpr:" (get $n :op) "(" (length (get $n :args)) ") ")]
                    [(= (get $n :kind) "literal")
                     (str $acc (get $n :type) ":" (get $n :value) " ")]
                    [(= (get $n :kind) "variable")
                     (str $acc "var:" (get $n :name) " ")]
                    [(= (get $n :kind) "keyword")
                     (str $acc "kw:" (get $n :name) " ")]
                    [(= (get $n :kind) "block")
                     (str $acc "block:" (get $n :type) " ")]
                    [true (str $acc "?" (get $n :kind) " ")]))
                "" $nodes)]

[FUNC check :params [$label $src $expected]
  :body (let [[$got (ast-summary (parse (lex $src)))]]
          (if (= $got $expected)
            (println (str "pass " $label))
            (println (str "fail " $label " expected=\"" $expected "\" got=\"" $got "\""))))]

(check "num"      "42"         "number:42 ")
(check "sym"      "foo"        "symbol:foo ")
(check "var"      "$x"         "var:x ")
(check "kw"       ":name"      "kw:name ")
(check "sexpr"    "(+ 1 2)"    "sexpr:+(2) ")
(check "nested"   "(+ (* 2 3) 4)"  "sexpr:+(2) ")
(check "array"    "[1 2 3]"    "block:Array ")
(check "map"      "{:a 1}"     "block:Map ")
(check "if"       "(if true 1 0)" "sexpr:if(3) ")
(check "funcblk"  "[FUNC add :params []]" "block:FUNC ")
