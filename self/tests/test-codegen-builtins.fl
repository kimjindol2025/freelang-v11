;; builtins codegen 검증: 각 범주 대표 smoke 30+ 개
;; self/codegen.fl 의 cg-native + runtime-prelude 를 직접 적재해 사용.

;; ═══════ 인라인 최소 codegen (cg-native 부분만 실측) ═══════
[FUNC js-esc :params [$s]
  :body (let [[$a (replace $s "\\" "\\\\")] [$b (replace $a "\"" "\\\"")]]
          (str "\"" $b "\""))]
[FUNC js-name :params [$n]
  :body (if (null? $n) "_"
          (let [[$a (replace $n "-" "_")] [$b (replace $a "?" "_q")] [$c (replace $b "!" "_x")]]
            $c))]

[FUNC cg :params [$n]
  :body (cond [(null? $n) "null"]
              [(= (get $n :kind) "literal") (cg-literal $n)]
              [(= (get $n :kind) "variable") (js-name (get $n :name))]
              [(= (get $n :kind) "keyword") (js-esc (get $n :name))]
              [(= (get $n :kind) "sexpr") (cg-sexpr $n)]
              [(= (get $n :kind) "block") (cg-block $n)]
              [true "null"])]

[FUNC cg-block :params [$n]
  :body (let [[$t (get $n :type)]]
          (cond [(= $t "Array")
                 (str "[" (cg-args (get (get $n :fields) "items")) "]")]
                [(= $t "Map")
                 (str "{" (cg-map-fields (get $n :fields)) "}")]
                [true "null"]))]

;; Map fields: JS Map → object literal
;; 현재 iteration 불가 → 하드코딩 대안으로 get all keys via keys(fields) if available
;; fallback: 이 테스트에서 map-literal 사용 안 하고 list 로 대체
[FUNC cg-map-fields :params [$f] :body ""]

[FUNC cg-literal :params [$n]
  :body (let [[$t (get $n :type)] [$v (get $n :value)]]
          (cond [(= $t "number") $v] [(= $t "string") (js-esc $v)]
                [(= $t "symbol")
                 (cond [(= $v "true") "true"] [(= $v "false") "false"] [(= $v "null") "null"]
                       [true (js-name $v)])]
                [true "null"]))]

[FUNC cg-args :params [$args] :body (args-loop $args 0 "")]
[FUNC args-loop :params [$args $i $acc]
  :body (if (>= $i (length $args)) $acc
          (let [[$c (str (cg (get $args $i)))]]
            (args-loop $args (+ $i 1) (if (= $i 0) $c (str $acc "," $c)))))]

[FUNC cg-pair :params [$args $op]
  :body (str "(" (cg (get $args 0)) $op (cg (get $args 1)) ")")]

[FUNC cg-sexpr :params [$n]
  :body (let [[$op (get $n :op)] [$args (get $n :args)] [$as (cg-args $args)]]
          (cond
            ;; 산술
            [(= $op "+") (cg-pair $args "+")]
            [(= $op "-") (cg-pair $args "-")]
            [(= $op "*") (cg-pair $args "*")]
            [(= $op "=") (cg-pair $args "===")]
            [(= $op "<") (cg-pair $args "<")]
            [(= $op ">") (cg-pair $args ">")]
            [(= $op "println") (str "console.log(" $as ")")]
            ;; String
            [(= $op "str") (str "_fl_str(" $as ")")]
            [(= $op "length") (str "_fl_length(" $as ")")]
            [(= $op "substring") (str "_fl_substring(" $as ")")]
            [(= $op "char-at") (str "_fl_char_at(" $as ")")]
            [(= $op "replace") (str "_fl_replace(" $as ")")]
            [(= $op "starts-with?") (str "_fl_starts_with(" $as ")")]
            [(= $op "ends-with?") (str "_fl_ends_with(" $as ")")]
            [(= $op "contains?") (str "_fl_contains(" $as ")")]
            [(= $op "split") (str "_fl_split(" $as ")")]
            [(= $op "join") (str "_fl_join(" $as ")")]
            [(= $op "trim") (str "_fl_trim(" $as ")")]
            [(= $op "upper") (str "_fl_upper(" $as ")")]
            [(= $op "lower") (str "_fl_lower(" $as ")")]
            [(= $op "repeat") (str "_fl_repeat(" $as ")")]
            [(= $op "index-of") (str "_fl_index_of(" $as ")")]
            ;; List
            [(= $op "first") (str "_fl_first(" $as ")")]
            [(= $op "last") (str "_fl_last(" $as ")")]
            [(= $op "rest") (str "_fl_rest(" $as ")")]
            [(= $op "append") (str "_fl_append(" $as ")")]
            [(= $op "slice") (str "_fl_slice(" $as ")")]
            [(= $op "list") (str "[" $as "]")]
            [(= $op "map") (str "_fl_map(" $as ")")]
            [(= $op "filter") (str "_fl_filter(" $as ")")]
            [(= $op "reduce") (str "_fl_reduce(" $as ")")]
            [(= $op "sort") (str "_fl_sort(" $as ")")]
            [(= $op "reverse") (str "_fl_reverse(" $as ")")]
            [(= $op "distinct") (str "_fl_distinct(" $as ")")]
            [(= $op "range") (str "_fl_range(" $as ")")]
            [(= $op "take") (str "_fl_take(" $as ")")]
            [(= $op "drop") (str "_fl_drop(" $as ")")]
            [(= $op "flatten") (str "_fl_flatten(" $as ")")]
            ;; Map
            [(= $op "get") (str "_fl_get(" $as ")")]
            [(= $op "keys") (str "_fl_keys(" $as ")")]
            [(= $op "values") (str "_fl_values(" $as ")")]
            [(= $op "has-key?") (str "_fl_has_key(" $as ")")]
            [(= $op "merge") (str "_fl_merge(" $as ")")]
            ;; JSON
            [(= $op "json-parse") (str "JSON.parse(" $as ")")]
            [(= $op "json-stringify") (str "JSON.stringify(" $as ")")]
            ;; Type
            [(= $op "null?") (str "(" $as "==null)")]
            [(= $op "string?") (str "(typeof " $as "===\"string\")")]
            [(= $op "number?") (str "(typeof " $as "===\"number\")")]
            [(= $op "list?") (str "Array.isArray(" $as ")")]
            [(= $op "type-of") (str "_fl_type_of(" $as ")")]
            ;; Math
            [(= $op "abs") (str "Math.abs(" $as ")")]
            [(= $op "max") (str "Math.max(" $as ")")]
            [(= $op "min") (str "Math.min(" $as ")")]
            [(= $op "floor") (str "Math.floor(" $as ")")]
            [(= $op "ceil") (str "Math.ceil(" $as ")")]
            [(= $op "mod") (cg-pair $args "%")]
            [(= $op "define") (str "const " (js-name (get (get $args 0) :value)) "=" (cg (get $args 1)))]
            [(= $op "fn")
             (str "((" (fn-params (get (get $args 0) :fields)) ")=>" (cg (get $args 1)) ")")]
            [true (str (js-name $op) "(" $as ")")]))]

[FUNC extract-name :params [$n]
  :body (cond [(= (get $n :kind) "variable") (js-name (get $n :name))]
              [(= (get $n :kind) "literal") (js-name (get $n :value))]
              [true "_anon"])]

[FUNC fn-params :params [$fields]
  :body (let [[$items (get $fields "items")]]
          (fn-params-loop $items 0 ""))]
[FUNC fn-params-loop :params [$items $i $acc]
  :body (if (>= $i (length $items)) $acc
          (let [[$jn (extract-name (get $items $i))]]
            (fn-params-loop $items (+ $i 1)
                            (if (= $i 0) $jn (str $acc "," $jn))))) ]

;; ═══════ runtime prelude (동일 — self/codegen.fl 과 중복) ═══════
(define PRELUDE
  (str
    "const _fl_str = (...xs) => xs.map(x => x==null?'null':String(x)).join('');"
    "const _fl_length = (x) => (x==null ? 0 : x.length);"
    "const _fl_substring = (s, a, b) => (b==null ? s.slice(a) : s.slice(a, b));"
    "const _fl_char_at = (s, i) => (s[i] || null);"
    "const _fl_replace = (s, a, b) => s.split(a).join(b);"
    "const _fl_starts_with = (s, p) => s.startsWith(p);"
    "const _fl_ends_with = (s, p) => s.endsWith(p);"
    "const _fl_contains = (s, p) => s.includes(p);"
    "const _fl_split = (s, sep) => s.split(sep);"
    "const _fl_join = (l, sep) => l.join(sep==null?'':sep);"
    "const _fl_trim = (s) => s.trim();"
    "const _fl_upper = (s) => s.toUpperCase();"
    "const _fl_lower = (s) => s.toLowerCase();"
    "const _fl_repeat = (s, n) => s.repeat(n);"
    "const _fl_index_of = (s, p) => s.indexOf(p);"
    "const _fl_first = (l) => (l==null || l.length===0 ? null : l[0]);"
    "const _fl_last = (l) => (l==null || l.length===0 ? null : l[l.length-1]);"
    "const _fl_rest = (l) => (l==null || l.length===0 ? [] : l.slice(1));"
    "const _fl_append = (a, b) => (Array.isArray(b) ? [...a, ...b] : [...a, b]);"
    "const _fl_slice = (l, a, b) => l.slice(a, b);"
    "const _fl_map = (f, l) => l.map(x => f(x));"
    "const _fl_filter = (f, l) => l.filter(x => f(x));"
    "const _fl_reduce = (f, init, l) => l.reduce((acc, x) => f(acc, x), init);"
    "const _fl_sort = (l, cmp) => [...l].sort(cmp || ((a,b)=>a<b?-1:a>b?1:0));"
    "const _fl_reverse = (l) => [...l].reverse();"
    "const _fl_distinct = (l) => [...new Set(l)];"
    "const _fl_range = (a, b, s) => { let r=[]; let step=s||1; for(let i=a;i<b;i+=step)r.push(i); return r; };"
    "const _fl_take = (n, l) => l.slice(0, n);"
    "const _fl_drop = (n, l) => l.slice(n);"
    "const _fl_flatten = (l) => l.flat(Infinity);"
    "const _fl_get = (o, k) => (o==null ? null : (o[k]===undefined ? null : o[k]));"
    "const _fl_keys = (o) => (o==null ? [] : Object.keys(o));"
    "const _fl_values = (o) => (o==null ? [] : Object.values(o));"
    "const _fl_has_key = (o, k) => (o!=null && k in o);"
    "const _fl_merge = (...os) => Object.assign({}, ...os);"
    "const _fl_is_map = (x) => (x!=null && typeof x==='object' && !Array.isArray(x));"
    "const _fl_type_of = (x) => (x==null?'null':Array.isArray(x)?'list':typeof x);"
    "\n"))

[FUNC compile-all :params [$ast $i $acc]
  :body (if (>= $i (length $ast)) $acc
          (compile-all $ast (+ $i 1) (str $acc (cg (get $ast $i)) ";\n")))]

[FUNC run-js :params [$label $fl $expected]
  :body (let [[$ast (fl-parse $fl)]
              [$js (str PRELUDE (compile-all $ast 0 ""))]
              [$file (str "self/bench/_bi_" $label ".js")]]
          (file_write $file $js)
          (let [[$r (shell_capture (str "node " $file))]
                [$out (get $r :stdout)]
                [$trim (if (null? $out) "" (replace $out "\n" ""))]]
            (if (= $trim $expected)
              (println (str "pass " $label "=" $trim))
              (println (str "fail " $label " expected=\"" $expected "\" got=\"" $trim "\"")))))]

;; ─── String (10) ───
(run-js "str-starts" "(println (starts-with? \"hello world\" \"hello\"))" "true")
(run-js "str-ends" "(println (ends-with? \"hello world\" \"world\"))" "true")
(run-js "str-contains" "(println (contains? \"hello world\" \"lo w\"))" "true")
(run-js "str-split" "(println (join (split \"a,b,c\" \",\") \"-\"))" "a-b-c")
(run-js "str-trim" "(println (trim \"  hi  \"))" "hi")
(run-js "str-upper" "(println (upper \"hi\"))" "HI")
(run-js "str-lower" "(println (lower \"HI\"))" "hi")
(run-js "str-repeat" "(println (repeat \"ab\" 3))" "ababab")
(run-js "str-index" "(println (index-of \"hello\" \"ll\"))" "2")
(run-js "str-concat" "(println (str \"hello\" \" \" \"world\"))" "hello world")

;; ─── List (10) ───
(run-js "list-first" "(println (first [10 20 30]))" "10")
(run-js "list-last" "(println (last [10 20 30]))" "30")
(run-js "list-map-inc" "(println (map (fn [x] (+ x 1)) [1 2 3]))" "[ 2, 3, 4 ]")
(run-js "list-filter-even" "(println (filter (fn [x] (= (mod x 2) 0)) [1 2 3 4 5]))" "[ 2, 4 ]")
(run-js "list-reduce-sum" "(println (reduce (fn [a b] (+ a b)) 0 [1 2 3 4]))" "10")
(run-js "list-sort" "(println (sort [3 1 4 1 5 9 2 6]))" "[  1, 1, 2, 3,  4, 5, 6, 9]")
(run-js "list-reverse" "(println (reverse [1 2 3]))" "[ 3, 2, 1 ]")
(run-js "list-distinct" "(println (distinct [1 2 2 3 3 3 4]))" "[ 1, 2, 3, 4 ]")
(run-js "list-range" "(println (range 0 5))" "[ 0, 1, 2, 3, 4 ]")
(run-js "list-take" "(println (take 3 [10 20 30 40 50]))" "[ 10, 20, 30 ]")

;; ─── Map (3) — JSON으로 맵 생성 우회 (map-literal codegen 미구현) ───
(run-js "map-keys" "(println (keys (json-parse \"{\\\"a\\\":1,\\\"b\\\":2}\")))" "[ 'a', 'b' ]")
(run-js "map-values" "(println (values (json-parse \"{\\\"a\\\":1,\\\"b\\\":2}\")))" "[ 1, 2 ]")
(run-js "map-has" "(println (has-key? (json-parse \"{\\\"a\\\":1}\") \"a\"))" "true")

;; ─── JSON (2) ───
(run-js "json-parse" "(println (get (json-parse \"{\\\"x\\\":42}\") \"x\"))" "42")
(run-js "json-str" "(println (json-stringify (json-parse \"{\\\"a\\\":1,\\\"b\\\":2}\")))" "{\"a\":1,\"b\":2}")

;; ─── Type (5) ───
(run-js "t-null" "(println (null? null))" "true")
(run-js "t-string" "(println (string? \"hi\"))" "true")
(run-js "t-number" "(println (number? 42))" "true")
(run-js "t-list" "(println (list? [1 2]))" "true")
(run-js "t-typeof" "(println (type-of \"hi\"))" "string")

;; ─── Math (5) — fl-parse 가 standalone 음수 literal 을 잘 처리하지 않아 뺄셈 우회 ───
(run-js "m-abs" "(println (abs (- 0 7)))" "7")
(run-js "m-max" "(println (max 3 7 2 9 1))" "9")
(run-js "m-min" "(println (min 3 7 2 9 1))" "1")
(run-js "m-floor" "(println (floor 3.7))" "3")
(run-js "m-mod" "(println (mod 10 3))" "1")
