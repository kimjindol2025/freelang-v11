;; P07 smoke: native-dispatch 에 위임된 builtins 가
;; self-interp 실행 경로에서 올바르게 동작하는지 검증.

;; ═══════ Lexer ═══════
[FUNC is-digit? :params [$c] :body (if (null? $c) false (and (>= $c "0") (<= $c "9")))]
[FUNC is-alpha? :params [$c]
  :body (if (null? $c) false
          (or (and (>= $c "a") (<= $c "z")) (and (>= $c "A") (<= $c "Z"))))]
[FUNC is-alnum? :params [$c] :body (or (is-digit? $c) (is-alpha? $c))]
[FUNC is-space? :params [$c] :body (or (= $c " ") (= $c "\t") (= $c "\n") (= $c "\r"))]
[FUNC is-symbol-char? :params [$c]
  :body (if (null? $c) false
          (or (is-alnum? $c) (= $c "-") (= $c "_") (= $c "?") (= $c "!")
              (= $c "/") (= $c ".") (= $c "<") (= $c ">") (= $c "=")
              (= $c "+") (= $c "*") (= $c "%")))]
[FUNC make-state :params [$src] :body {:src $src :idx 0 :line 1 :col 1 :tokens []}]
[FUNC peek-at :params [$st $o]
  :body (let [[$s (get $st :src)] [$i (+ (get $st :idx) $o)]]
          (if (>= $i (length $s)) null (char-at $s $i)))]
[FUNC peek :params [$st] :body (peek-at $st 0)]
[FUNC at-end? :params [$st] :body (>= (get $st :idx) (length (get $st :src)))]
[FUNC advance :params [$st]
  :body (let [[$c (peek $st)]]
          (if (= $c "\n")
            {:src (get $st :src) :idx (+ (get $st :idx) 1) :line (+ (get $st :line) 1) :col 1 :tokens (get $st :tokens)}
            {:src (get $st :src) :idx (+ (get $st :idx) 1) :line (get $st :line) :col (+ (get $st :col) 1) :tokens (get $st :tokens)}))]
[FUNC emit :params [$st $k $v $sl $sc]
  :body {:src (get $st :src) :idx (get $st :idx) :line (get $st :line) :col (get $st :col)
         :tokens (append (get $st :tokens) (list {:kind $k :value $v :line $sl :col $sc}))}]
[FUNC skip-ws :params [$st]
  :body (if (at-end? $st) $st
          (let [[$c (peek $st)]]
            (if (is-space? $c) (skip-ws (advance $st)) $st)))]
[FUNC read-number-body :params [$st $a $d $l $c]
  :body (if (at-end? $st) (emit $st "Number" $a $l $c)
          (let [[$ch (peek $st)]]
            (cond [(is-digit? $ch) (read-number-body (advance $st) (str $a $ch) $d $l $c)]
                  [(and (= $ch ".") (not $d)) (read-number-body (advance $st) (str $a $ch) true $l $c)]
                  [true (emit $st "Number" $a $l $c)])))]
[FUNC read-number :params [$st] :body (read-number-body $st "" false (get $st :line) (get $st :col))]
[FUNC read-string-body :params [$st $a $l $c]
  :body (if (at-end? $st) (emit $st "String" $a $l $c)
          (let [[$ch (peek $st)]]
            (cond [(= $ch "\"") (emit (advance $st) "String" $a $l $c)]
                  [true (read-string-body (advance $st) (str $a $ch) $l $c)])))]
[FUNC read-string :params [$st]
  :body (let [[$l (get $st :line)] [$c (get $st :col)] [$s1 (advance $st)]]
          (read-string-body $s1 "" $l $c))]
[FUNC read-sym-body :params [$st $a $l $c $k]
  :body (if (at-end? $st) (emit $st $k $a $l $c)
          (let [[$ch (peek $st)]]
            (if (is-symbol-char? $ch) (read-sym-body (advance $st) (str $a $ch) $l $c $k)
              (emit $st $k $a $l $c))))]
[FUNC read-symbol :params [$st] :body (read-sym-body $st "" (get $st :line) (get $st :col) "Symbol")]
[FUNC read-variable :params [$st]
  :body (let [[$l (get $st :line)] [$c (get $st :col)] [$s1 (advance $st)]]
          (read-sym-body $s1 "" $l $c "Variable"))]
[FUNC read-token :params [$st]
  :body (let [[$s1 (skip-ws $st)]]
          (if (at-end? $s1) $s1
            (let [[$c (peek $s1)] [$l (get $s1 :line)] [$col (get $s1 :col)]]
              (cond
                [(= $c "(") (emit (advance $s1) "LParen" $c $l $col)]
                [(= $c ")") (emit (advance $s1) "RParen" $c $l $col)]
                [(= $c "[") (emit (advance $s1) "LBracket" $c $l $col)]
                [(= $c "]") (emit (advance $s1) "RBracket" $c $l $col)]
                [(= $c "\"") (read-string $s1)]
                [(= $c "$") (read-variable $s1)]
                [(is-digit? $c) (read-number $s1)]
                [(and (= $c "-") (is-digit? (peek-at $s1 1)))
                 (read-number-body (advance $s1) "-" false $l $col)]
                [(is-symbol-char? $c) (read-symbol $s1)]
                [true (emit (advance $s1) "Unknown" $c $l $col)]))))]
[FUNC lex-loop :params [$st]
  :body (let [[$s1 (skip-ws $st)]]
          (if (at-end? $s1) (get $s1 :tokens) (lex-loop (read-token $s1))))]
[FUNC lex :params [$src] :body (lex-loop (make-state $src))]

;; ═══════ AST + Parser ═══════
[FUNC make-literal :params [$t $v $l] :body {:kind "literal" :type $t :value $v :line $l}]
[FUNC make-variable :params [$n $l] :body {:kind "variable" :name $n :line $l}]
[FUNC make-sexpr :params [$op $args $l] :body {:kind "sexpr" :op $op :args $args :line $l}]
[FUNC make-array-block :params [$items $l]
  :body {:kind "block" :type "Array" :name null :fields {:items $items} :line $l}]

[FUNC p-make :params [$t] :body {:tokens $t :idx 0}]
[FUNC p-peek :params [$p]
  :body (let [[$i (get $p :idx)] [$t (get $p :tokens)]]
          (if (>= $i (length $t)) null (get $t $i)))]
[FUNC p-end? :params [$p] :body (>= (get $p :idx) (length (get $p :tokens)))]
[FUNC p-advance :params [$p] :body {:tokens (get $p :tokens) :idx (+ (get $p :idx) 1)}]
[FUNC r-pair :params [$p $n] :body {:p $p :node $n}]

[FUNC parse-atom :params [$p]
  :body (let [[$t (p-peek $p)] [$k (get $t :kind)] [$v (get $t :value)] [$l (get $t :line)]]
          (cond
            [(= $k "Number") (r-pair (p-advance $p) (make-literal "number" $v $l))]
            [(= $k "String") (r-pair (p-advance $p) (make-literal "string" $v $l))]
            [(= $k "Symbol") (r-pair (p-advance $p) (make-literal "symbol" $v $l))]
            [(= $k "Variable") (r-pair (p-advance $p) (make-variable $v $l))]
            [true (r-pair (p-advance $p) (make-literal "unknown" $v $l))]))]

[FUNC parse-expr :params [$p]
  :body (let [[$t (p-peek $p)] [$k (get $t :kind)]]
          (cond
            [(= $k "LParen") (parse-sexpr $p)]
            [(= $k "LBracket") (parse-array $p)]
            [true (parse-atom $p)]))]

[FUNC parse-args :params [$p $acc]
  :body (let [[$t (p-peek $p)]]
          (cond [(null? $t) (r-pair $p $acc)]
                [(= (get $t :kind) "RParen") (r-pair $p $acc)]
                [(= (get $t :kind) "RBracket") (r-pair $p $acc)]
                [true (let [[$one (parse-expr $p)]]
                        (parse-args (get $one :p) (append $acc (list (get $one :node)))))]))]

[FUNC parse-sexpr :params [$p]
  :body (let [[$tok (p-peek $p)] [$line (get $tok :line)] [$p1 (p-advance $p)]
              [$coll (parse-args $p1 [])] [$p2 (get $coll :p)] [$args (get $coll :node)]
              [$p3 (if (and (not (null? (p-peek $p2))) (= (get (p-peek $p2) :kind) "RParen"))
                     (p-advance $p2) $p2)]]
          (if (= (length $args) 0) (r-pair $p3 (make-sexpr "" (list) $line))
            (let [[$op-n (get $args 0)]
                  [$op (cond [(= (get $op-n :kind) "literal") (get $op-n :value)]
                             [(= (get $op-n :kind) "variable") (str "$" (get $op-n :name))]
                             [true "unknown"])]
                  [$rest (slice $args 1 (length $args))]]
              (r-pair $p3 (make-sexpr $op $rest $line)))))]

[FUNC parse-array :params [$p]
  :body (let [[$tok (p-peek $p)] [$line (get $tok :line)] [$p1 (p-advance $p)]
              [$coll (parse-args $p1 [])] [$p2 (get $coll :p)] [$items (get $coll :node)]
              [$p3 (if (and (not (null? (p-peek $p2))) (= (get (p-peek $p2) :kind) "RBracket"))
                     (p-advance $p2) $p2)]]
          (r-pair $p3 (make-array-block $items $line)))]

[FUNC parse-all :params [$p $acc]
  :body (if (p-end? $p) $acc
          (let [[$one (parse-expr $p)]]
            (parse-all (get $one :p) (append $acc (list (get $one :node))))))]

[FUNC parse :params [$tokens] :body (parse-all (p-make $tokens) [])]

;; ═══════ Scope ═══════
[FUNC make-scope :params [] :body (list {})]
[FUNC push-scope :params [$s] :body (append (list {}) $s)]
[FUNC norm-key :params [$k]
  :body (if (null? $k) ""
          (if (and (>= (length $k) 1) (= (char-at $k 0) "$"))
            (substring $k 1 (length $k)) $k))]
[FUNC scope-get-loop :params [$s $k $i]
  :body (cond [(>= $i (length $s)) null]
              [(not (null? (get (get $s $i) $k))) (get (get $s $i) $k)]
              [true (scope-get-loop $s $k (+ $i 1))])]
[FUNC scope-get :params [$s $k] :body (scope-get-loop $s (norm-key $k) 0)]
[FUNC scope-set :params [$s $k $v]
  :body (let [[$nk (norm-key $k)] [$top (get $s 0)] [$rest (slice $s 1 (length $s))]]
          (append (list (json_set $top $nk $v)) $rest))]

;; ═══════ Builtins (native-dispatch) ═══════
[FUNC add-loop :params [$vs $i $acc]
  :body (if (>= $i (length $vs)) $acc (add-loop $vs (+ $i 1) (+ $acc (get $vs $i))))]
[FUNC mul-loop :params [$vs $i $acc]
  :body (if (>= $i (length $vs)) $acc (mul-loop $vs (+ $i 1) (* $acc (get $vs $i))))]
[FUNC str-loop :params [$vs $i $acc]
  :body (if (>= $i (length $vs)) $acc (str-loop $vs (+ $i 1) (str $acc (get $vs $i))))]

[FUNC native-dispatch :params [$op $vs]
  :body (cond
          [(= $op "+")         (add-loop $vs 0 0)]
          [(= $op "-")         (if (= (length $vs) 1) (- 0 (get $vs 0)) (- (get $vs 0) (add-loop $vs 1 0)))]
          [(= $op "*")         (mul-loop $vs 0 1)]
          [(= $op "/")         (/ (get $vs 0) (get $vs 1))]
          [(= $op "%")         (% (get $vs 0) (get $vs 1))]
          [(= $op "abs")       (let [[$v (get $vs 0)]] (if (< $v 0) (- 0 $v) $v))]
          [(= $op "<")         (< (get $vs 0) (get $vs 1))]
          [(= $op ">")         (> (get $vs 0) (get $vs 1))]
          [(= $op "<=")        (<= (get $vs 0) (get $vs 1))]
          [(= $op ">=")        (>= (get $vs 0) (get $vs 1))]
          [(= $op "=")         (= (get $vs 0) (get $vs 1))]
          [(= $op "!=")        (not (= (get $vs 0) (get $vs 1)))]
          [(= $op "not")       (not (get $vs 0))]
          [(= $op "null?")     (null? (get $vs 0))]
          [(= $op "str")       (str-loop $vs 0 "")]
          [(= $op "concat")    (str-loop $vs 0 "")]
          [(= $op "length")    (length (get $vs 0))]
          [(= $op "substring") (if (>= (length $vs) 3) (substring (get $vs 0) (get $vs 1) (get $vs 2)) (substring (get $vs 0) (get $vs 1)))]
          [(= $op "char-at")   (char-at (get $vs 0) (get $vs 1))]
          [(= $op "str-to-num") (str-to-num (get $vs 0))]
          [(= $op "list")      $vs]
          [(= $op "first")     (get (get $vs 0) 0)]
          [(= $op "last")      (let [[$l (get $vs 0)]] (if (= (length $l) 0) null (get $l (- (length $l) 1))))]
          [(= $op "rest")      (let [[$l (get $vs 0)]] (if (= (length $l) 0) (list) (slice $l 1 (length $l))))]
          [(= $op "append")    (append (get $vs 0) (get $vs 1))]
          [(= $op "get")       (get (get $vs 0) (get $vs 1))]
          [(= $op "slice")     (slice (get $vs 0) (get $vs 1) (get $vs 2))]
          [(= $op "println")   (println (if (= (length $vs) 0) "" (get $vs 0)))]
          [true (error (str "native-dispatch unknown: " $op))])]

;; ═══════ Interpreter (builtins 에 위임) ═══════
[FUNC truthy? :params [$v]
  :body (cond [(null? $v) false] [(= $v false) false] [(= $v 0) false] [(= $v "") false] [true true])]

[FUNC strip-dollar :params [$s]
  :body (if (null? $s) $s
          (if (and (>= (length $s) 1) (= (char-at $s 0) "$"))
            (substring $s 1 (length $s)) $s))]

[FUNC get-name :params [$n]
  :body (cond [(= (get $n :kind) "variable") (get $n :name)]
              [(= (get $n :kind) "literal") (get $n :value)]
              [true "_"])]

[FUNC extract-params :params [$pnode]
  :body (if (null? $pnode) (list)
          (let [[$items (get (get $pnode :fields) "items")]]
            (if (null? $items) (list) (map (fn [$x] (get-name $x)) $items))))]

[FUNC self-eval :params [$node $scope]
  :body (cond
          [(null? $node) null]
          [(= (get $node :kind) "literal") (eval-literal $node $scope)]
          [(= (get $node :kind) "variable") (eval-variable $node $scope)]
          [(= (get $node :kind) "sexpr") (eval-sexpr $node $scope)]
          [true null])]

[FUNC eval-literal :params [$n $scope]
  :body (let [[$t (get $n :type)] [$v (get $n :value)]]
          (cond
            [(= $t "number") (str-to-num $v)]
            [(= $t "string") $v]
            [(= $t "symbol")
             (cond
               [(= $v "null") null]
               [(= $v "true") true]
               [(= $v "false") false]
               [true (let [[$rv (scope-get $scope $v)]]
                       (if (null? $rv) $v $rv))])]
            [true $v]))]

[FUNC eval-variable :params [$n $scope]
  :body (let [[$name (get $n :name)] [$v (scope-get $scope $name)]]
          (if (null? $v) (error (str "Undefined: $" $name)) $v))]

[FUNC eval-args-list :params [$args $scope $i $acc]
  :body (if (>= $i (length $args)) $acc
          (eval-args-list $args $scope (+ $i 1)
                          (append $acc (list (self-eval (get $args $i) $scope)))))]

[FUNC apply-user-fn :params [$fv $vals]
  :body (let [[$params (get $fv :params)] [$body (get $fv :body)]
              [$captured (get $fv :capturedEnv)] [$name (get $fv :name)]
              [$captured1 (if (null? $name) $captured (scope-set $captured $name $fv))]
              [$scope2 (push-scope $captured1)]
              [$scope3 (bind-params $params $vals $scope2 0)]]
          (self-eval $body $scope3))]

[FUNC bind-params :params [$params $vals $scope $i]
  :body (if (>= $i (length $params)) $scope
          (bind-params $params $vals
                       (scope-set $scope (get $params $i) (get $vals $i)) (+ $i 1)))]

[FUNC eval-sexpr :params [$n $scope]
  :body (let [[$op (get $n :op)] [$args (get $n :args)]]
          (cond
            [(= $op "if")
             (if (truthy? (self-eval (get $args 0) $scope))
               (self-eval (get $args 1) $scope)
               (if (>= (length $args) 3) (self-eval (get $args 2) $scope) null))]
            [(= $op "fn")
             (let [[$pnode (get $args 0)] [$body (get $args 1)] [$ps (extract-params $pnode)]]
               {:kind "function-value" :params $ps :body $body :capturedEnv $scope :name null})]
            [(= $op "defn")
             (let [[$name (get-name (get $args 0))]
                   [$pnode (get $args 1)] [$body (get $args 2)]
                   [$ps (extract-params $pnode)]
                   [$fv {:kind "function-value" :params $ps :body $body :capturedEnv $scope :name $name}]]
               {:kind "__defn__" :name $name :fv $fv})]
            [true
             (let [[$clean (strip-dollar $op)]
                   [$fv (scope-get $scope $clean)]
                   [$vs (eval-args-list $args $scope 0 (list))]]
               (if (and (not (null? $fv)) (= (get $fv :kind) "function-value"))
                 (apply-user-fn $fv $vs)
                 (native-dispatch $clean $vs)))]))]

[FUNC run-ast :params [$ast $scope $i $last]
  :body (if (>= $i (length $ast)) $last
          (let [[$v (self-eval (get $ast $i) $scope)]]
            (if (and (not (null? $v)) (= (get $v :kind) "__defn__"))
              (run-ast $ast (scope-set $scope (get $v :name) (get $v :fv)) (+ $i 1) $last)
              (run-ast $ast $scope (+ $i 1) $v))))]

[FUNC self-run :params [$src] :body (run-ast (parse (lex $src)) (make-scope) 0 null)]

;; ═══════ Phase 07 smoke — 35+ 케이스 ═══════
[FUNC check :params [$label $actual $expected]
  :body (if (= $actual $expected)
          (println (str "pass " $label "=" $actual))
          (println (str "fail " $label " expected=" $expected " got=" $actual)))]

;; 산술
(check "add"      (self-run "(+ 1 2 3 4)")     10)
(check "sub1"     (self-run "(- 10)")          (- 0 10))
(check "sub2"     (self-run "(- 20 5 3)")      12)
(check "mul"      (self-run "(* 2 3 4)")       24)
(check "div"      (self-run "(/ 100 4)")       25)
(check "mod"      (self-run "(% 10 3)")        1)
(check "abs-neg"  (self-run "(abs -7)")        7)

;; 비교
(check "lt"       (self-run "(< 3 5)")         true)
(check "gt-f"     (self-run "(> 3 5)")         false)
(check "le"       (self-run "(<= 5 5)")        true)
(check "ge"       (self-run "(>= 6 5)")        true)
(check "eq"       (self-run "(= 3 3)")         true)
(check "ne"       (self-run "(!= 3 4)")        true)

;; 논리
(check "not-t"    (self-run "(not 0)")         true)
(check "null-t"   (self-run "(null? null)")    true)

;; 문자열
(check "str"      (self-run "(str 1 2 3)")     "123")
(check "concat"   (self-run "(concat \"a\" \"b\")") "ab")
(check "length-s" (self-run "(length \"hello\")") 5)
(check "substr"   (self-run "(substring \"hello\" 1 4)") "ell")

;; 리스트
(check "list"     (self-run "(length (list 1 2 3))") 3)
(check "first"    (self-run "(first (list 10 20 30))") 10)
(check "last"     (self-run "(last (list 10 20 30))") 30)
(check "get-idx"  (self-run "(get (list 100 200 300) 1)") 200)

;; 조합
(check "nested"   (self-run "(+ (* 2 3) (- 10 4))") 12)
(check "user-fn"  (self-run "(defn sq [$x] (* $x $x)) (sq 7)") 49)
(check "fact5"    (self-run "(defn fact [$n] (if (<= $n 1) 1 (* $n (fact (- $n 1))))) (fact 5)") 120)
(check "fact7"    (self-run "(defn fact [$n] (if (<= $n 1) 1 (* $n (fact (- $n 1))))) (fact 7)") 5040)
