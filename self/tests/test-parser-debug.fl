;; Extract parser from test-parser.fl and test it
[FUNC is-digit? :params [c] :body (if (null? c) false (and (>= c "0") (<= c "9")))]
[FUNC make-state :params [src] :body {:src src :idx 0 :line 1 :col 1 :tokens []}]
[FUNC peek :params [st] :body (let [[i (get st :idx)] [s (get st :src)]] (if (>= i (length s)) null (char-at s i)))]
[FUNC at-end? :params [st] :body (>= (get st :idx) (length (get st :src)))]
[FUNC advance :params [st] :body {:src (get st :src) :idx (+ (get st :idx) 1) :line (get st :line) :col (+ (get st :col) 1) :tokens (get st :tokens)}]
[FUNC emit :params [st k v sl sc] :body {:src (get st :src) :idx (get st :idx) :line (get st :line) :col (get st :col) :tokens (append (get st :tokens) (list {:type k :value v :line sl :col sc}))}]
[FUNC read-number-body :params [st a d l c] :body (if (at-end? st) (emit st "Number" a l c) (let [[ch (peek st)]] (cond [(is-digit? ch) (read-number-body (advance st) (str a ch) d l c)] [true (emit st "Number" a l c)])))]
[FUNC read-number :params [st] :body (read-number-body st "" false (get st :line) (get st :col))]
[FUNC lex-loop :params [st] :body (if (at-end? st) (get st :tokens) (let [[c (peek st)]] (if (is-digit? c) (lex-loop (read-number st)) (lex-loop (advance st)))))]
[FUNC fl-lex :params [src] :body (lex-loop (make-state src))]

;; Parser structures
[FUNC p-make :params [tokens] :body {:tokens tokens :idx 0 :ast []}]
[FUNC p-peek :params [p] :body (let [[i (get p :idx)] [t (get p :tokens)]] (if (>= i (length t)) null (get t i)))]
[FUNC p-advance :params [p] :body {:tokens (get p :tokens) :idx (+ (get p :idx) 1) :ast (get p :ast)}]
[FUNC p-end? :params [p] :body (>= (get p :idx) (length (get p :tokens)))]
[FUNC p-with-ast :params [p a] :body {:tokens (get p :tokens) :idx (get p :idx) :ast a}]
[FUNC p-append-ast :params [p n] :body (p-with-ast p (append (get p :ast) (list n)))]
[FUNC r-pair :params [p n] :body {:p p :node n}]

[FUNC make-literal :params [t v l] :body {:kind "literal" :type t :value v :line l}]

;; Very simple parser that just returns atoms
[FUNC parse-atom :params [p] :body (let [[t (p-peek p)]] (if (null? t) (r-pair p (make-literal "unknown" "null" 0)) (r-pair (p-advance p) (make-literal "number" (get t :value) 1))))]
[FUNC parse-expr :params [p] :body (parse-atom p)]
[FUNC parse-all :params [p] :body (if (p-end? p) (get p :ast) (let [[one (parse-expr p)] [p2 (p-append-ast (get one :p) (get one :node))]] (parse-all p2)))]
[FUNC fl-parse :params [tokens] :body (parse-all (p-make tokens))]

;; Test
(println "=== Testing Parser ===")
(let [[tokens (fl-lex "42")]]
  (println (str "1. Lexer output: " tokens))
  (let [[ast (fl-parse tokens)]]
    (println (str "2. Parser output: " ast))))
