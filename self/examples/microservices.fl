(println "      # 터미널 1: User Service")
(println "      PORT=3001 node bootstrap.js serve")
(println "")
(println "      # 터미널 2: Product Service")
(println "      PORT=3002 node bootstrap.js serve")
(println "")
(println "      # 터미널 3: Order Service")
(println "      PORT=3003 node bootstrap.js serve")
(println "")
(println "      # 터미널 4: Gateway")
(println "      PORT=3000 node bootstrap.js serve")

(println "\n   2️⃣ 또는 Docker Compose로 한 번에:")
(println "      docker-compose up")

(println "\n📡 테스트 예제:")
