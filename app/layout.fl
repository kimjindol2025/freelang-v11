(do
  (set-meta! {:title "FreeLang v11" :description "AI-Native 풀스택 언어 — SSR, 자가 호스팅, 제로 외부 의존성"})
  "<!DOCTYPE html>
<html lang=\"ko\">
<head>
  <meta charset=\"UTF-8\">
  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">
  <title>FreeLang v11</title>
  <style>
    :root {
      --fg: #1b1b1f;
      --muted: #57606a;
      --accent: #6f42c1;
      --accent-light: #8a63d2;
      --bg: #fbfbfd;
      --card: #ffffff;
      --line: #e4e6eb;
      --code-bg: #0d1117;
      --code-fg: #c9d1d9;
    }
    * { box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Noto Sans KR', sans-serif;
      margin: 0;
      background: var(--bg);
      color: var(--fg);
      line-height: 1.6;
    }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    code {
      background: #f1f3f5;
      padding: 2px 6px;
      border-radius: 4px;
      font-size: 13px;
      font-family: 'SF Mono', Consolas, monospace;
    }
    pre {
      background: var(--code-bg);
      color: var(--code-fg);
      padding: 16px 18px;
      border-radius: 8px;
      overflow-x: auto;
      font-size: 13px;
      line-height: 1.5;
    }
    pre code { background: transparent; padding: 0; color: inherit; }
    nav.site-nav {
      background: #fff;
      border-bottom: 1px solid var(--line);
      padding: 14px 24px;
      display: flex;
      align-items: center;
      gap: 20px;
      position: sticky;
      top: 0;
      z-index: 10;
    }
    nav.site-nav .brand {
      font-weight: 700;
      font-size: 16px;
      color: var(--fg);
      margin-right: auto;
    }
    nav.site-nav .brand span { color: var(--accent); }
    nav.site-nav a {
      font-size: 14px;
      color: var(--muted);
    }
    nav.site-nav a:hover { color: var(--accent); text-decoration: none; }
    main.site-main {
      max-width: 900px;
      margin: 0 auto;
      padding: 32px 24px 64px;
    }
    footer.site-footer {
      border-top: 1px solid var(--line);
      padding: 20px 24px;
      text-align: center;
      color: var(--muted);
      font-size: 12px;
    }
    section { margin-bottom: 28px; }
    h1 { font-size: 32px; margin: 0 0 12px; letter-spacing: -0.02em; }
    h2 { font-size: 20px; margin: 24px 0 10px; }
    h3 { font-size: 16px; margin: 18px 0 8px; }
    .lede { color: var(--muted); font-size: 17px; margin: 0 0 24px; }
    .cta-row { display: flex; gap: 10px; flex-wrap: wrap; margin: 18px 0; }
    .btn {
      display: inline-block;
      padding: 10px 18px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 14px;
      text-decoration: none;
    }
    .btn-primary { background: var(--accent); color: #fff; }
    .btn-primary:hover { background: var(--accent-light); text-decoration: none; }
    .btn-ghost { border: 1px solid var(--line); color: var(--fg); }
    .btn-ghost:hover { border-color: var(--accent); color: var(--accent); text-decoration: none; }
    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 14px;
      margin: 18px 0;
    }
    .card {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 18px 20px;
    }
    .card h3 { margin-top: 0; }
    .kv {
      display: grid;
      grid-template-columns: 140px 1fr;
      gap: 6px 14px;
      font-size: 14px;
      margin: 10px 0;
    }
    .kv dt { color: var(--muted); }
    .kv dd { margin: 0; }
    .tag {
      display: inline-block;
      padding: 2px 10px;
      background: var(--accent);
      color: #fff;
      border-radius: 999px;
      font-size: 12px;
      vertical-align: middle;
      margin-left: 6px;
    }
  </style>
</head>
<body>
  <nav class=\"site-nav\">
    <a href=\"/\" class=\"brand\">Free<span>Lang</span> v11</a>
    <a href=\"/\">Home</a>
    <a href=\"/examples\">Examples</a>
    <a href=\"/playground\">Playground</a>
    <a href=\"/docs\">Docs</a>
    <a href=\"/claude\">Claude Demo</a>
  </nav>
  <main class=\"site-main\">
    {{children}}
  </main>
  <footer class=\"site-footer\">
    FreeLang v11 · Self-hosted fixed-point · bootstrap.js SSR
  </footer>
</body>
</html>")
