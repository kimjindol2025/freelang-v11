[SERVICE UserService
  :methods {
    find-all (fn [] [{id 1 name "Alice"} {id 2 name "Bob"}])
    find-by-id (fn [$id] {id $id name "User"})
  }
]

[CONTROLLER UserController
  :prefix "/api/users"
  :routes {
    list (fn [$req] (UserService.find-all))
    detail (fn [$req] (UserService.find-by-id 1))
  }
]

[GUARD AuthGuard
  :strategy "jwt"
  :check (fn [$token] (not (nil? $token)))
]
