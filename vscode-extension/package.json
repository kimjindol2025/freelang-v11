{
  "name": "freelang",
  "displayName": "FreeLang v11",
  "description": "Syntax highlighting, snippets, and icons for FreeLang v11 (.fl files).",
  "version": "11.2.0",
  "publisher": "freelang",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Programming Languages", "Snippets"],
  "contributes": {
    "languages": [
      {
        "id": "freelang",
        "aliases": ["FreeLang", "freelang", "FL"],
        "extensions": [".fl"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "freelang",
        "scopeName": "source.fl",
        "path": "./syntaxes/freelang.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "freelang",
        "path": "./snippets/freelang.json"
      }
    ]
  }
}
