(let [[src (file-read "self/bench/hello.fl")]
      [tokens (lex src)]
      [ast (parse tokens)]]
  (do
    (println (str "Total nodes: " (length ast)))
    (let [[i 0]]
      (while (< i (length ast))
        (let [[node (get ast i)]]
          (do
            (println (str "  [" i "] kind=" (get node "kind") " op=" (get node "op")))
            (set! i (+ i 1))))))))
