{
  "name": "freelang-v11",
  "version": "11.2.0",
  "description": "FreeLang v11 — Unified AI-Native Language (v9 Runtime + Web Framework). [v11.2: L3 Self-Hosting 완성 — stage1.js가 자기 자신을 컴파일]",
  "keywords": [
    "ai",
    "language",
    "freelang",
    "s-expression",
    "ai-native",
    "claude",
    "agent"
  ],
  "author": "Claude Code (Anthropic)",
  "license": "MIT",
  "homepage": "https://gogs.dclub.kr/kim/freelang-v11",
  "main": "dist/index.js",
  "bin": {
    "v9": "dist/cli.js"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "docs:gen": "node scripts/gen-stdlib-docs.js",
    "compile": "node --stack-size=8000 stage1.js",
    "compile:self": "node --stack-size=8000 stage1.js self/all.fl stage1-new.js",
    "verify:fixed-point": "bash scripts/verify-fixed-point-deep.sh",
    "verify:build-deterministic": "bash scripts/verify-build-deterministic.sh",
    "verify:self-host": "bash scripts/verify-self-host.sh tier2",
    "test": "jest --config .config/jest.fast.config.js --passWithNoTests",
    "test:fast": "jest --config .config/jest.fast.config.js --passWithNoTests",
    "test:full": "jest --config .config/jest.config.js --passWithNoTests",
    "test:watch": "jest --config .config/jest.fast.config.js --watch",
    "test:coverage": "jest --config .config/jest.config.js --coverage",
    "test:ci": "jest --config .config/jest.config.js --ci --coverage --maxWorkers=2",
    "benchmark": "node scripts/benchmark.js",
    "dev": "node bootstrap.js run app/page.fl",
    "start": "node bootstrap.js serve app/",
    "server": "node bootstrap.js serve app/",
    "freelang": "node bootstrap.js run",
    "fl": "node bootstrap.js run",
    "repl": "node bootstrap.js repl"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.37",
    "esbuild": "^0.21.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "mongodb": "^7.2.0",
    "mysql2": "^3.22.3",
    "sharp": "^0.34.5"
  }
}
