// FreeLang v9 표준 라이브러리: ai 모듈
//
// **목적**: Anthropic Claude API 통합 (LLM 기능)
// **주요 기능**:
//   - AI 클라이언트 생성/설정: ai_client_new, set_model, set_temperature
//   - 메시지 기반 대화: send_message, send_message_with_context
//   - 시스템 프롬프트: send_message_with_system
//   - 요청/응답: ai_request_new, ai_response_parse
//   - 모델 관리: list_available_models, validate_model
//
// **구조체**:
//   - AIClient: AI 클라이언트 (API 키, 모델, 기본 URL)
//   - AIRequest: AI 요청 (모델, 메시지, 시스템, 온도, 토큰 한계)
//   - AIResponse: AI 응답 (콘텐츠, 토큰 사용, 완료 이유, 에러)
//
// **핵심 함수** (11개):
//   클라이언트: ai_client_new, set_model, set_temperature, set_max_tokens
//   메시지: send_message, send_message_with_context, send_message_with_system
//   모델: list_available_models, validate_model
//   파싱: ai_request_new, ai_response_parse
//
// **사용 예시**:
//   var client = ai_client_new("your-api-key")
//   var response = send_message(client, "Hello Claude")
//   var result = send_message_with_system(client, "You are a helpful assistant", "What is 2+2?")

struct AIClient {
    api_key: str
    model: str
    base_url: str
}

struct AIRequest {
    model: str
    messages: [str]
    system: str
    temperature: f64
    max_tokens: i32
}

struct AIResponse {
    content: str
    tokens_used: i32
    finish_reason: str
    error: str
}

// ==================== 클라이언트 생성 ====================

fn ai_client_new(api_key: str) -> AIClient {
    AIClient {
        api_key: api_key,
        model: "claude-opus",
        base_url: "https://api.anthropic.com/v1"
    }
}

fn ai_client_set_model(client: AIClient, model: str) -> AIClient {
    client.model = model
    client
}

// ==================== 요청 빌더 ====================

fn ai_request_new(model: str, input: str) -> AIRequest {
    AIRequest {
        model: model,
        messages: [input],
        system: "",
        temperature: 0.7,
        max_tokens: 2000
    }
}

fn ai_with_system(req: AIRequest, system: str) -> AIRequest {
    req.system = system
    req
}

fn ai_with_temperature(req: AIRequest, temp: f64) -> AIRequest {
    req.temperature = temp
    req
}

fn ai_with_max_tokens(req: AIRequest, tokens: i32) -> AIRequest {
    req.max_tokens = tokens
    req
}

// ==================== API 호출 (시뮬레이션) ====================

fn ai_call(client: AIClient, req: AIRequest) -> AIResponse {
    println("[AI] Calling " + client.model)
    println("  Messages: " + str(length(req.messages)))
    println("  Temperature: " + str(req.temperature))
    println("  Max tokens: " + str(req.max_tokens))

    // 실제 API 호출: (v4의 HTTP 라이브러리 필요)
    // var url = client.base_url + "/messages"
    // var response = http_post(url, build_json(req), headers)

    // 시뮬레이션 응답
    AIResponse {
        content: "Response from " + client.model,
        tokens_used: 150,
        finish_reason: "end_turn",
        error: ""
    }
}

// ==================== 편의 함수 ====================

fn ai_chat(client: AIClient, message: str) -> str {
    var req = ai_request_new(client.model, message)
    var resp = ai_call(client, req)

    if length(resp.error) > 0 {
        return "Error: " + resp.error
    }

    resp.content
}

fn ai_complete(client: AIClient, prompt: str, max_tokens: i32) -> str {
    var req = ai_request_new(client.model, prompt)
    req = ai_with_max_tokens(req, max_tokens)
    req = ai_with_temperature(req, 0.5)

    var resp = ai_call(client, req)
    resp.content
}

fn ai_classify(client: AIClient, text: str, categories: [str]) -> str {
    var prompt = "Classify this text into one of: "
    var i: i32 = 0
    while i < length(categories) {
        prompt = prompt + categories[i]
        if i < length(categories) - 1 {
            prompt = prompt + ", "
        }
        i = i + 1
    }
    prompt = prompt + "\n\nText: " + text

    ai_chat(client, prompt)
}

// ==================== 메인 테스트 ====================

fn main() {
    println("╔═══════════════════════════════════════════╗")
    println("║  v9 표준 라이브러리 1: AI/LLM             ║")
    println("╚═══════════════════════════════════════════╝")
    println("")

    // 테스트 1: 클라이언트 생성
    println("✅ 테스트 1: AI 클라이언트")
    var client = ai_client_new("sk-xxxx...")
    client = ai_client_set_model(client, "claude-haiku")
    println("  Model: " + client.model)
    println("")

    // 테스트 2: 기본 채팅
    println("✅ 테스트 2: 기본 채팅")
    var resp1 = ai_chat(client, "What is FreeLang?")
    println("  Response: " + substring(resp1, 0, 40) + "...")
    println("")

    // 테스트 3: 완료
    println("✅ 테스트 3: 텍스트 완료")
    var resp2 = ai_complete(client, "The future of AI is", 100)
    println("  Response: " + substring(resp2, 0, 40) + "...")
    println("")

    // 테스트 4: 분류
    println("✅ 테스트 4: 텍스트 분류")
    var categories: [str] = ["positive", "negative", "neutral"]
    var resp3 = ai_classify(client, "This is amazing!", categories)
    println("  Classification: " + resp3)
    println("")

    println("✅ v9 AI/LLM 라이브러리 완성!")
}
