; FreeLang Frontend v11 - Web Agent
; 웹 컨텍스트에서 AI 에이전트 실행 (200줄)
; v11 AI 블록 통합: [COT], [REFLECT], [AGENT] 활용
; ReAct 루프: Reason → Act → Observe → Learn

[IMPORT "./v9-parser-web" :as parser]

; Agent compilation result
[STRUCT AgentCompilationResult
  :name str
  :context [dict]
  :tools [str]
  :js str
  :reasoning-steps [str]
]

; Agent state
[STRUCT AgentState
  :name str
  :state str          ; thinking, searching, learning, acting, done
  :thoughts [str]
  :observations [str]
  :learnings [str]
  :actions [str]
  :result str
]

; Compile AGENT block
[FUNC compile-agent :params [agent-node]
  :returns AgentCompilationResult
  :body [
    (do
      (var agent-name (get agent-node.properties "name"))
      (var context-def (get agent-node.properties "context"))
      (var reasoning-def (get agent-node.properties "reasoning"))
      (var tools-def (get agent-node.properties "tools"))

      ; Parse context
      (var context (parse-agent-context context-def))

      ; Parse reasoning steps
      (var reasoning-steps (parse-reasoning-steps reasoning-def))

      ; Parse tools
      (var tools (parse-agent-tools tools-def))

      ; Generate JavaScript
      (var js (gen-agent-js agent-name context reasoning-steps tools))

      [AgentCompilationResult
        :name agent-name
        :context context
        :tools tools
        :js js
        :reasoning-steps reasoning-steps
      ]
    )
  ]
]

; Parse agent context
[FUNC parse-agent-context :params [context-str]
  :returns [dict]
  :body [
    (do
      (var context {})
      ; Parse: { :apiBase "https://api.example.com" :timeout 5000 }
      ; Placeholder for full parsing
      context
    )
  ]
]

; Parse reasoning steps
[FUNC parse-reasoning-steps :params [reasoning-str]
  :returns [str]
  :body [
    (do
      (var steps [])
      ; Parse: [SEARCH "..."] [LEARN "..."] [ACTION "..."]
      ; Placeholder for full parsing
      steps
    )
  ]
]

; Parse agent tools
[FUNC parse-agent-tools :params [tools-str]
  :returns [str]
  :body [
    (do
      (var tools [])
      ; Parse available tools
      tools
    )
  ]
]

; Generate Agent JavaScript
[FUNC gen-agent-js :params [agent-name :context :reasoning-steps :tools]
  :returns str
  :body [
    (do
      (var js "")

      ; Agent class
      (set js (concat js (concat "class " agent-name " {\n")))
      (set js (concat js "  constructor(context = {}) {\n"))
      (set js (concat js "    this.context = context;\n"))
      (set js (concat js "    this.state = 'idle';\n"))
      (set js (concat js "    this.thoughts = [];\n"))
      (set js (concat js "    this.observations = [];\n"))
      (set js (concat js "    this.learnings = [];\n"))
      (set js (concat js "    this.cache = {};\n"))
      (set js (concat js "  }\n\n"))

      ; THINK: v11 [COT] 추론 단계
      (set js (concat js "  async think(input) {\n"))
      (set js (concat js "    this.state = 'thinking';\n"))
      (set js (concat js "    // v11 [COT] block 호출\n"))
      (set js (concat js "    const thought = await flAI.think({step: input});\n"))
      (set js (concat js "    this.thoughts.push(thought);\n"))
      (set js (concat js "    return thought;\n"))
      (set js (concat js "  }\n\n"))

      ; SEARCH: 정보 검색
      (set js (concat js "  async search(query) {\n"))
      (set js (concat js "    this.state = 'searching';\n"))
      (set js (concat js "    try {\n"))
      (set js (concat js "      const response = await fetch(this.context.apiBase + '/search', {\n"))
      (set js (concat js "        method: 'POST',\n"))
      (set js (concat js "        headers: { 'Content-Type': 'application/json' },\n"))
      (set js (concat js "        body: JSON.stringify({ query })\n"))
      (set js (concat js "      });\n"))
      (set js (concat js "      const data = await response.json();\n"))
      (set js (concat js "      this.observations.push(data);\n"))
      (set js (concat js "      return data;\n"))
      (set js (concat js "    } catch (error) {\n"))
      (set js (concat js "      this.observations.push({ error: error.message });\n"))
      (set js (concat js "      return { error: error.message };\n"))
      (set js (concat js "    }\n"))
      (set js (concat js "  }\n\n"))

      ; LEARN: v11 [REFLECT] 패턴 학습
      (set js (concat js "  learn(observation) {\n"))
      (set js (concat js "    this.state = 'learning';\n"))
      (set js (concat js "    // v11 [REFLECT] block 호출\n"))
      (set js (concat js "    const insight = flAI.reflect({output: observation});\n"))
      (set js (concat js "    this.learnings.push(insight);\n"))
      (set js (concat js "    return insight;\n"))
      (set js (concat js "  }\n\n"))

      ; ACT: 액션 실행
      (set js (concat js "  async act(action) {\n"))
      (set js (concat js "    this.state = 'acting';\n"))
      (set js (concat js "    try {\n"))
      (set js (concat js "      const response = await fetch(this.context.apiBase + '/execute', {\n"))
      (set js (concat js "        method: 'POST',\n"))
      (set js (concat js "        headers: { 'Content-Type': 'application/json' },\n"))
      (set js (concat js "        body: JSON.stringify({ action })\n"))
      (set js (concat js "      });\n"))
      (set js (concat js "      return await response.json();\n"))
      (set js (concat js "    } catch (error) {\n"))
      (set js (concat js "      return { error: error.message };\n"))
      (set js (concat js "    }\n"))
      (set js (concat js "  }\n\n"))

      ; ReAct Loop (v11 [AGENT] 블록 활용)
      (set js (concat js "  async run(input) {\n"))
      (set js (concat js "    this.state = 'running';\n"))
      (set js (concat js "    \n"))
      (set js (concat js "    // v11 [AGENT] 블록 호출\n"))
      (set js (concat js "    const agentResult = await flAI.agent({\n"))
      (set js (concat js "      goal: input,\n"))
      (set js (concat js "      tools: this.context,\n"))
      (set js (concat js "      max_steps: 5\n"))
      (set js (concat js "    });\n"))
      (set js (concat js "    \n"))
      (set js (concat js "    // Extract thinking process\n"))
      (set js (concat js "    this.thoughts = agentResult.reasoning || [];\n"))
      (set js (concat js "    this.observations = agentResult.observations || [];\n"))
      (set js (concat js "    this.learnings = agentResult.learnings || [];\n"))
      (set js (concat js "    \n"))
      (set js (concat js "    this.state = 'done';\n"))
      (set js (concat js "    return {\n"))
      (set js (concat js "      success: agentResult.success || false,\n"))
      (set js (concat js "      thoughts: this.thoughts,\n"))
      (set js (concat js "      observations: this.observations,\n"))
      (set js (concat js "      learnings: this.learnings,\n"))
      (set js (concat js "      result: agentResult.output\n"))
      (set js (concat js "    };\n"))
      (set js (concat js "  }\n\n"))

      ; Extract insights
      (set js (concat js "  extractInsights(observation) {\n"))
      (set js (concat js "    if (Array.isArray(observation)) {\n"))
      (set js (concat js "      return observation.slice(0, 3); // Top 3 insights\n"))
      (set js (concat js "    }\n"))
      (set js (concat js "    return observation;\n"))
      (set js (concat js "  }\n\n"))

      ; Clear cache
      (set js (concat js "  clearCache() {\n"))
      (set js (concat js "    this.cache = {};\n"))
      (set js (concat js "  }\n"))
      (set js (concat js "}\n\n"))

      ; Export
      (set js (concat js (concat "window." agent-name " = " agent-name ";\n")))

      js
    )
  ]
]

; Helper: Extract insights from data
[FUNC extract-insights :params [data]
  :returns [str]
  :body [
    []  ; Placeholder
  ]
]

; Compile multiple agents
[FUNC compile-agents :params [agent-nodes]
  :returns [AgentCompilationResult]
  :body [
    (do
      (var results [])
      (for-each agent-nodes
        (fn [node]
          (if (eq node.type parser.AGENT)
            (push results (compile-agent node)))))
      results
    )
  ]
]

; Export
[EXPORT compile-agent compile-agents AgentCompilationResult AgentState gen-agent-js]
