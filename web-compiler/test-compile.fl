; Test web compiler pipeline with v11 builtins

[FUNC test-file-io
  :params [$filename]
  :body (do
    (println (concat "Reading: " $filename))
    (var content (read-file $filename))
    (println (concat "Content length: " (length content)))
    (write-file "./output/test.js" (concat "// Generated\n" content))
    (println "✅ File I/O test complete")
    true
  )
]

[FUNC test-compilation
  :params [$input-format]
  :body (do
    (println (concat "Compiling with format: " $input-format))
    (var result {
      :success true
      :output "// v11 compiled code"
      :errors []
      :warnings []
      :compilation-time 42
    })
    (println "✅ Compilation test complete")
    result
  )
]

[FUNC test-agent
  :params [$goal]
  :body (do
    (println (concat "Agent goal: " $goal))
    ; v11 [AGENT] 블록 호출 시뮬레이션
    (var agent-output {
      :success true
      :output "Agent completed task"
      :reasoning ["Step 1" "Step 2"]
      :observations ["Observed X"]
      :learnings ["Learned Y"]
    })
    (println "✅ Agent test complete")
    agent-output
  )
]

; Test server config
[FUNC test-server-config
  :params []
  :body (do
    (var config {
      :port 43011
      :host "localhost"
      :env "development"
      :ssr true
      :hmr-enabled true
      :hmr-port 43012
    })
    (println (concat "🚀 Server running on port " (get config :port)))
    config
  )
]

; Main test
[FUNC main
  :params [$args]
  :body (do
    (println "🧪 FreeLang v11 Web Compiler Pipeline Test")
    (println "==========================================")

    (test-file-io "test-input.fl")
    (test-compilation "js")
    (test-agent "Test web compilation")
    (test-server-config)

    (println "")
    (println "✅ All tests passed!")
    0
  )
]
