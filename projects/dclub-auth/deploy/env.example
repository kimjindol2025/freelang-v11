# dclub-auth 운영 환경변수
# 배포 시: sudo cp env.example /etc/dclub-auth/env
#          sudo chown dclub-auth:dclub-auth /etc/dclub-auth/env
#          sudo chmod 600 /etc/dclub-auth/env

# ── 기본 ──────────────────────────────────────────────
DCLUB_AUTH_PORT=30100
DCLUB_AUTH_ISSUER=https://auth.dclub.kr
DCLUB_AUTH_DB=/var/lib/dclub-auth/auth.db

# ── 메일 outbox (sendmail/postfix queue 호환) ────────
DCLUB_AUTH_MAIL_OUTBOX=/var/lib/dclub-auth/outbox
DCLUB_AUTH_MAIL_FROM=no-reply@dclub.kr

# ── (선택) 직접 SMTP 발송 — 자동 cron 또는 외부 worker ─
# DCLUB_AUTH_SMTP_HOST=smtp.gmail.com
# DCLUB_AUTH_SMTP_PORT=465
# DCLUB_AUTH_SMTP_USER=alerts@dclub.kr
# DCLUB_AUTH_SMTP_PASS=app-password-goes-here

# ── Node.js ───────────────────────────────────────────
NODE_ENV=production
