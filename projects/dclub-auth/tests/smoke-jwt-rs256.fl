;; smoke-jwt-rs256.fl — Phase A.2 라이브 검증
;; 실행: node bootstrap.js run projects/dclub-auth/tests/smoke-jwt-rs256.fl

(load "projects/dclub-auth/lib/jwt-rs256.fl")

(define keys (crypto_rsa_generate 2048))
(define pub (get $keys "publicKey"))
(define priv (get $keys "privateKey"))

;; ── 1. 정상 발급·검증 ────────────────────────────────
(define token1 (jwt-rs256-sign
  {"sub" "user-42" "iss" "https://auth.dclub.kr" "aud" "blog"}
  $priv
  "key-1"
  3600))

(println (str "[1] token len = " (length $token1)))

(define payload1 (jwt-rs256-verify $token1 $pub))
(println (str "[1] verify: sub=" (get $payload1 "sub")
              " iss=" (get $payload1 "iss")
              " aud=" (get $payload1 "aud")))

;; ── 2. 변조 거부 ─────────────────────────────────────
(define tampered (str $token1 "X"))
(define p2 (jwt-rs256-verify $tampered $pub))
(println (str "[2] tampered verify = " $p2))

;; ── 3. 다른 키쌍의 공개키로 거부 ─────────────────────
(define keysB (crypto_rsa_generate 2048))
(define p3 (jwt-rs256-verify $token1 (get $keysB "publicKey")))
(println (str "[3] wrong-key verify = " $p3))

;; ── 4. 만료 토큰 거부 (음수 expiry) ─────────────────
(define expired-token (jwt-rs256-sign {"sub" "u"} $priv "key-1" -10))
(define p4 (jwt-rs256-verify $expired-token $pub))
(println (str "[4] expired verify = " $p4))

;; ── 5. 디코드 (서명 검증 없음) ───────────────────────
(define decoded (jwt-rs256-decode $token1))
(define h (get $decoded "header"))
(define p (get $decoded "payload"))
(println (str "[5] decoded header alg=" (get $h "alg")
              " kid=" (get $h "kid")
              " typ=" (get $h "typ")))
(println (str "[5] decoded payload sub=" (get $p "sub")
              " has-iat=" (if (get $p "iat") "yes" "no")
              " has-exp=" (if (get $p "exp") "yes" "no")))

;; ── 6. header-only (kid 매칭) ────────────────────────
(define hdr (jwt-rs256-header-only $token1))
(println (str "[6] header-only kid=" (get $hdr "kid")))

(println "Phase A.2 smoke OK")
