;; connectors/memory.fl — Claude 메모리 시스템 인덱싱
;;
;; 디렉토리 listing stdlib (file_list) 부재로 인해 1차 단순:
;;   MEMORY.md 인덱스 파일 자체 인덱싱 (전체 내용 검색 가능)
;;
;; S1.2.1 후속 (file_list 추가 후 또는 manifest 기반):
;;   MEMORY.md 의 [Title](file.md) 패턴 추출 → 개별 .md 파일 인덱싱

(load "projects/freelang-search/lib/index-store.fl")

[FUNC memory-reindex :params [$db $memory-path]
  :body (let [
    index-path (str $memory-path "/MEMORY.md")
    content (file_read $index-path)
  ]
    (if (or (= $content nil) (= $content ""))
      {:source "memory" :indexed 0 :note (str "읽기 실패: " $index-path)}
      (do
        (fs-index-doc $db "memory-INDEX" "memory"
          "Claude Memory Index" $content "memory index" $index-path)
        {:source "memory" :indexed 1 :path $index-path})))]
