;; config.fl — dclub-keep

[FUNC keep-config-get :params [$key $default]
  :body (let [v (shell_env $key)]
    (if (= $v "") $default $v))]

[FUNC dclub-keep-config :params []
  :body {
    :db (keep-config-get "DCLUB_KEEP_DB" "/tmp/dclub-keep.db")
    :port (* (keep-config-get "DCLUB_KEEP_PORT" "30190") 1)
  }]

[FUNC nil-or-empty? :params [$v]
  :body (cond
    [(nil? $v) true]
    [(= $v nil) true]
    [(= $v "") true]
    [(= $v "null") true]
    [true false])]
