;; Bigwash Collector Tests (v9)
;; Phase 1: Basic collector validation

[DEFTEST "CPU 수집 반환값 검증"
  (let [$result (collect-cpu)]
    (assert-eq (ok? $result) true)
    (assert (number? (:value $result)))
    (assert (>= (:value $result) 0))
    (assert (<= (:value $result) 100)))]

[DEFTEST "RAM 수집 반환값 검증"
  (let [$result (collect-ram)]
    (assert-eq (ok? $result) true)
    (assert (number? (:value $result)))
    (assert (>= (:value $result) 0))
    (assert (<= (:value $result) 100)))]

[DEFTEST "Disk 수집 반환값 검증"
  (let [$result (collect-disk)]
    (assert-eq (ok? $result) true)
    (assert (number? (:value $result)))
    (assert (>= (:value $result) 0))
    (assert (<= (:value $result) 100)))]

[DEFTEST "Network 수집 반환값 검증"
  (let [$result (collect-network)]
    (assert-eq (ok? $result) true)
    (let [$net (:value $result)]
      (assert (has? $net :bytes-in))
      (assert (has? $net :bytes-out))
      (assert (number? (:bytes-in $net)))
      (assert (number? (:bytes-out $net)))))]

[DEFTEST "collect-all 통합 검증"
  (let [$result (collect-all)]
    (assert-eq (ok? $result) true)
    (let [$metrics (:value $result)]
      (assert (has? $metrics :cpu))
      (assert (has? $metrics :ram))
      (assert (has? $metrics :disk))
      (assert (has? $metrics :network))
      (assert (has? $metrics :timestamp))))]

[DEFTEST "CPU 값 범위 (0-100)"
  (let [$result (collect-cpu)
        $value (:value $result)]
    (assert (and (>= $value 0) (<= $value 100))))]

[DEFTEST "RAM 값 범위 (0-100)"
  (let [$result (collect-ram)
        $value (:value $result)]
    (assert (and (>= $value 0) (<= $value 100))))]

[DEFTEST "Disk 값 범위 (0-100)"
  (let [$result (collect-disk)
        $value (:value $result)]
    (assert (and (>= $value 0) (<= $value 100))))]

[DEFTEST "여러 번 수집 일관성"
  (let [$r1 (collect-all)
        $r2 (collect-all)
        $r3 (collect-all)]
    (assert-eq (ok? $r1) true)
    (assert-eq (ok? $r2) true)
    (assert-eq (ok? $r3) true)))
