{
  "agent": {
    "name": "agent-termux-001",
    "version": "0.1.0",
    "environment": "termux"
  },
  "collection": {
    "interval_ms": 5000,
    "buffer_size": 1000,
    "metrics": [
      "cpu_percent",
      "ram_percent",
      "disk_percent",
      "network_bytes"
    ]
  },
  "server": {
    "url": "https://bigwash.example.com",
    "port": 443,
    "tls": true
  },
  "auth": {
    "node_id": "node-termux-001",
    "api_key": "sk_test_abc123xyz",
    "token_refresh_seconds": 3600
  },
  "transport": {
    "batch_size": 100,
    "batch_interval_ms": 5000,
    "retry_max": 5,
    "retry_backoff_ms": 1000
  },
  "debug": {
    "enabled": false,
    "log_level": "info",
    "metrics_file": "metrics.jsonl"
  }
}
