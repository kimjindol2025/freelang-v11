(println "║                                                    ║")
(println "║ git clone 후 main.fl 실행:                          ║")
(println "║   export JWT_SECRET=$(openssl rand -hex 32)         ║")
(println "║   node bootstrap.js run main.fl                    ║")
(println "╚════════════════════════════════════════════════════╝")
(println "")
