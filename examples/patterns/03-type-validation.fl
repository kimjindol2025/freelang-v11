;; 패턴 3: 타입 검증 (Type Checking)
;; AI가 외부 입력을 처리할 때 필수

;; 패턴 A: 기본 타입 검증
(define calculate-discount (fn [price discount-percent]
  (if (not (number? price)) (throw "Price must be number"))
  (if (not (number? discount-percent)) (throw "Discount must be number"))
  (if (< price 0) (throw "Price cannot be negative"))
  (if (or (< discount-percent 0) (> discount-percent 100)) (throw "Discount must be 0-100"))
  (* price (- 1 (/ discount-percent 100)))))

;;; TEST: (calculate-discount 100 20) => 80

;; 패턴 B: 복합 타입 검증
(define process-user-list (fn [users]
  (if (not (array? users)) (throw "Users must be array"))
  (map (fn [user]
    (if (not (map? user)) (throw "Each user must be map"))
    (if (not (string? (get user :name))) (throw "User name must be string"))
    (if (not (number? (get user :age))) (throw "User age must be number"))
    user)
    users)))

;;; TEST: (length (process-user-list [{:name "Alice" :age 25}])) => 1

;; 패턴 C: nil 안전 처리 (Optional)
(define get-user-email (fn [user]
  (if (nil? user)
    nil
    (let [email (get user :email)]
      (if (nil? email)
        "no-email@example.com"
        email)))))

;;; TEST: (get-user-email {:name "Alice" :email "alice@example.com"}) => "alice@example.com"
;;; TEST: (get-user-email {:name "Bob"}) => "no-email@example.com"
;;; TEST: (get-user-email nil) => nil

;; 패턴 D: 조건부 타입 검증
(define convert-to-number (fn [value]
  (cond
    [(number? value) value]
    [(string? value) (try (str-to-num value) (catch e 0))]
    [true 0])))

;;; TEST: (convert-to-number 42) => 42
;;; TEST: (convert-to-number "100") => 100
;;; TEST: (convert-to-number "abc") => 0

;; 패턴 F: 배열 요소 타입 검증
(define sum-numbers (fn [numbers]
  (if (not (array? numbers)) (throw "Input must be array"))
  (let [valid (filter (fn [n] (number? n)) numbers)]
    (reduce (fn [acc n] (+ acc n)) 0 valid))))

;;; TEST: (sum-numbers [1 2 3 4 5]) => 15
;;; TEST: (sum-numbers [1 "two" 3 "four" 5]) => 9
