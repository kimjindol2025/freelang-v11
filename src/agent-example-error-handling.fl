; Agent DSL 예제 2: 간단한 작업 실행
; 실행: node bootstrap.js run src/agent-example-error-handling.fl

(load "src/agent-dsl.fl")

(println "════════════════════════════════════════")
(println "예제 2: 간단한 작업")
(println "════════════════════════════════════════")
(println "")

; Task 1: 첫 번째 작업
(let [task1 (make-task "task1" (fn [ctx]
  (do
    (println "→ Task 1: 첫 번째 작업")
    (println "✓ 완료")
    { :result "task1-result" }
  )
))]

  ; Task 2: 두 번째 작업
  (let [task2 (make-task "task2" (fn [ctx]
    (do
      (println "→ Task 2: 두 번째 작업")
      (println "✓ 완료")
      { :result "task2-result" }
    )
  ))]

    ; Task 3: 세 번째 작업
    (let [task3 (make-task "task3" (fn [ctx]
      (do
        (println "→ Task 3: 세 번째 작업")
        (println "✓ 완료")
        { :result "task3-result" }
      )
    ))]

      ; 실행
      (let [
        [result (agent-run [task1 task2 task3])]
      ] (do
        (println "")
        (println "════════════════════════════════════════")
        (println "작업 완료!")
        (println (str "상태: " (get result :status)))
        (println (str "총 단계: " (get result :total-steps)))
        (println "════════════════════════════════════════")
      ))
    )
  )
)
