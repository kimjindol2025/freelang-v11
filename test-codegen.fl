[SERVICE TodoService
  :inject [TodoRepository]
  :methods {
    :find-all (fn [$user-id] nil)
    :create (fn [$title $user-id] nil)
  }
]

[MODEL Todo
  :table "todos"
  :fields {
    :id (int :primary)
    :title (str :required)
    :completed (bool :default false)
  }
]

[CONTROLLER TodoController
  :prefix "/api/todos"
  :routes {
    :routes (["/" (fn [$req] nil)])
  }
]
