// FreeLang v9 실제 사용 예제
// 실무 사용 사례 및 데모

// ==================== 예제 1: 금융 거래 (INTENT) ====================

fn example_bank_transfer() {
    println("┌─────────────────────────────────┐")
    println("│ 예제 1: 은행 송금 (INTENT)      │")
    println("└─────────────────────────────────┘")
    println("")

    var code = "[INTENT transfer-money
        :from account:12345
        :to account:67890
        :amount 1000.00
        :currency USD
        :ensure (atomic)
        :retry 3
        :on-fail (rollback)
    ]"

    println("v9 코드:")
    println(code)
    println("")
    println("특징:")
    println("  • 원자적(atomic) 거래 보장")
    println("  • 실패 시 3회 재시도")
    println("  • 실패 시 자동 롤백")
    println("")
}

// ==================== 예제 2: 데이터 분석 파이프라인 (PIPE) ====================

fn example_data_pipeline() {
    println("┌─────────────────────────────────┐")
    println("│ 예제 2: 데이터 분석 (PIPE)      │")
    println("└─────────────────────────────────┘")
    println("")

    var code = "[PIPE analyze-reviews
        :input reviews.csv
        :steps (
            (read-csv reviews.csv :as $data)
            (filter $data :where (> :length 10))
            (call classify-sentiment :each $data.:text)
            (aggregate $result :group-by :sentiment :count true)
            (write-json output.json $aggregated)
        )
        :output output.json
    ]"

    println("v9 코드:")
    println(code)
    println("")
    println("파이프라인:")
    println("  1. CSV 읽기")
    println("  2. 길이가 10 이상인 리뷰 필터링")
    println("  3. 각 텍스트의 감정 분류")
    println("  4. 감정별로 집계")
    println("  5. JSON 파일로 저장")
    println("")
}

// ==================== 예제 3: AI 에이전트 (AGENT) ====================

fn example_autonomous_agent() {
    println("┌─────────────────────────────────┐")
    println("│ 예제 3: 자율 에이전트 (AGENT)    │")
    println("└─────────────────────────────────┘")
    println("")

    var code = "[AGENT data-analyst
        :tools [
            read-csv
            analyze-data
            call-api
            write-json
            send-email
        ]
        :memory (vector-store analyst-memory 1000)
        :system \"You are a data analyst. Analyze datasets and provide insights.\"
        :loop true
        :max-iterations 10
        :stop-when (eq $task :done)
    ]"

    println("v9 코드:")
    println(code)
    println("")
    println("에이전트 기능:")
    println("  • 5개의 도구 사용 가능")
    println("  • 메모리 시스템 (1000차원 벡터)")
    println("  • 자동 루프 (max 10번)")
    println("  • :done 신호로 종료")
    println("")
}

// ==================== 예제 4: LLM 호출 (PROMPT) ====================

fn example_sentiment_classifier() {
    println("┌─────────────────────────────────┐")
    println("│ 예제 4: 감정 분류 (PROMPT)      │")
    println("└─────────────────────────────────┘")
    println("")

    var code = "[PROMPT classify-sentiment
        :input $review_text
        :model claude-haiku
        :system \"You are a sentiment classifier.\"
        :schema {
            :label (enum positive negative neutral)
            :confidence (float 0.0 1.0)
            :reason str
        }
        :temperature 0.3
        :out $result
    ]"

    println("v9 코드:")
    println(code)
    println("")
    println("특징:")
    println("  • Claude Haiku 모델 사용")
    println("  • 구조화된 출력 (JSON Schema)")
    println("  • 낮은 온도 (0.3) = 일관된 결과")
    println("  • 자동 재시도 포함")
    println("")
}

// ==================== 예제 5: 함수 정의 (FUNC) ====================

fn example_fibonacci_function() {
    println("┌─────────────────────────────────┐")
    println("│ 예제 5: Fibonacci 함수 (FUNC)   │")
    println("└─────────────────────────────────┘")
    println("")

    var code = "[FUNC fibonacci
        :in ($n :type int)
        :out (:type int)
        :pure true
        :cached true
        :body
            (match $n
                (<= 1)  => $n
                else    => (+
                    (call fibonacci (- $n 1))
                    (call fibonacci (- $n 2))
                )
            )
    ]"

    println("v9 코드:")
    println(code)
    println("")
    println("특징:")
    println("  • 순수 함수 (부작용 없음)")
    println("  • 자동 캐싱 (메모이제이션)")
    println("  • 패턴 매칭 지원")
    println("  • 재귀 호출")
    println("")
}

// ==================== 예제 6: 복합 워크플로우 ====================

fn example_complex_workflow() {
    println("┌─────────────────────────────────┐")
    println("│ 예제 6: 복합 워크플로우          │")
    println("└─────────────────────────────────┘")
    println("")

    var code = "[WORKFLOW customer-service
        :input $ticket
        :steps [
            ;; Step 1: 티켓 분류
            (call
                (call classify-sentiment :input $ticket.description)
                :as $sentiment
            )

            ;; Step 2: 우선순위 결정
            (call
                (call prioritize
                    :sentiment $sentiment
                    :keywords [urgent important critical]
                )
                :as $priority
            )

            ;; Step 3: 담당자 배정
            (call
                (call route-to-agent
                    :priority $priority
                    :category $ticket.category
                )
                :as $agent
            )

            ;; Step 4: 응답 생성
            (call
                (call generate-response
                    :ticket $ticket
                    :sentiment $sentiment
                    :agent $agent
                )
                :as $response
            )

            ;; Step 5: 저장 & 알림
            (call
                (seq
                    (save-to-db $ticket $response)
                    (send-notification $agent.email $ticket.id)
                )
            )
        ]
        :output $response
    ]"

    println("v9 코드:")
    println(code)
    println("")
    println("워크플로우:")
    println("  1. 감정 분석")
    println("  2. 우선순위 결정")
    println("  3. 담당자 라우팅")
    println("  4. AI 응답 생성")
    println("  5. 저장 및 알림")
    println("")
}

// ==================== 예제 7: 멀티 에이전트 시스템 ====================

fn example_multi_agent() {
    println("┌─────────────────────────────────┐")
    println("│ 예제 7: 멀티 에이전트 시스템     │")
    println("└─────────────────────────────────┘")
    println("")

    println("에이전트 1: 데이터 수집가")
    println("  [AGENT data-collector")
    println("    :tools [http-get, parse-json, store-db]")
    println("    :task :gather-market-data")
    println("  ]")
    println("")

    println("에이전트 2: 분석가")
    println("  [AGENT analyst")
    println("    :tools [analyze-trends, create-report, notify]")
    println("    :memory (await data-collector.output)")
    println("    :task :analyze")
    println("  ]")
    println("")

    println("에이전트 3: 의사결정자")
    println("  [AGENT decision-maker")
    println("    :tools [evaluate, recommend, execute]")
    println("    :memory (await analyst.report)")
    println("    :task :decide")
    println("  ]")
    println("")

    println("특징:")
    println("  • 3개 에이전트의 병렬 작업")
    println("  • 메모리/컨텍스트 공유")
    println("  • 비동기 대기 (await)")
    println("")
}

// ==================== 예제 8: 에러 처리 ====================

fn example_error_handling() {
    println("┌─────────────────────────────────┐")
    println("│ 예제 8: 에러 처리                │")
    println("└─────────────────────────────────┘")
    println("")

    var code = "[INTENT process-payment
        :amount $amount
        :card $card
        :try (
            (validate-card $card)
            (charge-card $card $amount)
            (log-transaction $card $amount)
        )
        :catch (err)
            (if (eq err.type :invalid-card)
                (notify-user \"Invalid card details\")
                (if (eq err.type :insufficient-funds)
                    (notify-user \"Insufficient funds\")
                    (notify-admin err)
                )
            )
        :finally (
            (cleanup-session)
            (log-attempt)
        )
    ]"

    println("v9 코드:")
    println(code)
    println("")
    println("에러 처리:")
    println("  • try: 메인 로직")
    println("  • catch: 에러별 처리")
    println("  • finally: 항상 실행 (정리)")
    println("")
}

