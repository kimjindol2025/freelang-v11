{"id":"T143_pattern_color","category":"pattern-match","difficulty":"easy","prompt":"색상 코드 r/g/b를 \"red\"/\"green\"/\"blue\"로 변환. (color-name \"g\")는 \"green\".","validation":{"type":"stdout_contains","expected":"green"},"reference_solution":"(defn color-name [c] (cond [(= c \"r\") \"red\"] [(= c \"g\") \"green\"] [(= c \"b\") \"blue\"] [true \"unknown\"]))\n(println (color-name \"g\"))","tags":["cond"]}
